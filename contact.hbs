{{!< default-contact}} 
{{#post}} {{#if featured}} {{#match @page.show_title_and_feature_image}} <div
    class="gh-post-head page-head{{^if feature_image}} without-image{{/if}}">
    {{#if feature_image}}
    <picture>
        <source srcset="{{img_url feature_image size="3000" format="webp" }} 3000w, {{img_url feature_image size="2000"
            format="webp" }} 2000w, {{img_url feature_image size="1200" format="webp" }} 1200w, {{img_url feature_image
            size="1000" format="webp" }} 1000w, {{img_url feature_image size="800" format="webp" }} 800w, {{img_url
            feature_image size="500" format="webp" }} 500w" sizes="100vw" type="image/webp">
        <img srcset="{{img_url feature_image size=" 1600"}} 3000w, {{img_url feature_image size="2000" }} 2000w,
            {{img_url feature_image size="1200" }} 1200w, {{img_url feature_image size="1000" }} 1000w, {{img_url
            feature_image size="800" }} 800w, {{img_url feature_image size="500" }} 500w" sizes="100vw"
            src="{{img_url feature_image size="3000"}}"
            alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
            class="gh-post-feature-image" />
    </picture>
    {{/if}}
    <div class="gh-post-head-wrapper page-head-wrapper gh-container{{#match @custom.header_type " Logo with bottom
        navigation" }} with-big-header{{else match @custom.header_type "Author with bottom navigation" }}
        with-big-header{{/match}}">
        {{> "breadcrumbs"}}
        <div class="gh-post-head-content">
            <div class="gh-post-head-content-container">
                <h1 class="gh-post-page-title">{{title}}</h1>
                {{#if excerpt}}
                <p class="gh-post-page-excerpt">{{excerpt}}</p>
                {{/if}}
            </div>
        </div>
    </div>
    </div>
    {{/match}}
    {{else}}
    {{#match @page.show_title_and_feature_image}}
    <div class="gh-container">
        {{> "breadcrumbs"}}
    </div>
    <div class="gh-post-head gh-container page-head{{^if feature_image}} without-image{{/if}}">
        <div class="gh-post-head-wrapper page-head-wrapper{{^if feature_image}} without-image{{/if}}">
            {{#if feature_image}}
            <picture>
                <source srcset="{{img_url feature_image size="1600" format="webp" }} 1600w, {{img_url feature_image
                    size="1200" format="webp" }} 1200w, {{img_url feature_image size="1000" format="webp" }} 1000w,
                    {{img_url feature_image size="800" format="webp" }} 800w, {{img_url feature_image size="500"
                    format="webp" }} 500w" sizes="(min-width: 816px) 736px, 90vw" type="image/webp">
                <img srcset="{{img_url feature_image size=" 1600"}} 1600w, {{img_url feature_image size="1200" }} 1200w,
                    {{img_url feature_image size="1000" }} 1000w, {{img_url feature_image size="800" }} 800w, {{img_url
                    feature_image size="500" }} 500w" sizes="(min-width: 816px) 736px, 90vw"
                    src="{{img_url feature_image size="1600"}}"
                    alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
                    class="gh-post-feature-image" />
            </picture>
            {{/if}}
            <div class="gh-post-head-content">
                <div class="gh-post-head-content-container">
                    <h1 class="gh-post-page-title">{{title}}</h1>
                    {{#if excerpt}}
                    <p class="gh-post-page-excerpt">{{excerpt}}</p>
                    {{/if}}
                </div>
            </div>
        </div>
    </div>
    {{/match}}
    {{/if}}

    {{/post}}


    <section class="sc-contact-hero" aria-labelledby="sc-contact-hero-title">
        <div class="sc-contact-hero-inner gh-container">
            <span class="sc-contact-hero-chip">{{t "Contact Us"}}</span>
            <h1 id="sc-contact-hero-title">{{t "Get in Touch"}} <span>{{t "With Us"}}</span></h1>
            <p>{{t "To communicate with the administration of Spaziocrypto.com, you have the contact form available within this page."}}</p>
        </div>
    </section>


    <main class="main flex-1">
        <section class="sc-contact-touch">
            <div class="sc-contact-touch-inner gh-container">
                <div class="sc-contact-touch-grid">
                    <div class="sc-contact-form-col">
                        <h2>{{t "Get In Touch"}}</h2>
                        <p>{{t "Our friendly team would love to hear from you."}}</p>

                        <form action="https://formspree.io/f/xwkdojlk" method="post" class="sc-contact-form" aria-label="Contact form">
                            <div class="sc-contact-form-row">
                                <label for="contact-first-name">{{t "First name"}}</label>
                                <input id="contact-first-name" name="first-name" type="text" placeholder="{{t "First name"}}" required>
                            </div>
                            <div class="sc-contact-form-row">
                                <label for="contact-last-name">{{t "Last name"}}</label>
                                <input id="contact-last-name" name="last-name" type="text" placeholder="{{t "Last name"}}" required>
                            </div>
                            <div class="sc-contact-form-row">
                                <label for="contact-email">{{t "Email"}}</label>
                                <input id="contact-email" name="email" type="email" placeholder="marketing@spaziocrypto.com" required>
                            </div>
                            <div class="sc-contact-form-row">
                                <label for="contact-message">{{t "Message"}}</label>
                                <textarea id="contact-message" name="message" rows="5" required></textarea>
                            </div>
                            <label class="sc-contact-consent">
                                <input type="checkbox" name="privacy" required>
                                <span>{{t "You agree to our friendly"}} <a href="/privacy-policy/">{{t "privacy policy"}}</a>.</span>
                            </label>
                            <button type="submit" class="sc-contact-submit">{{t "Send message"}}</button>
                        </form>
                    </div>

                    <div class="sc-contact-media-col">
                        <div class="sc-contact-media-card">
                            <img src="{{asset "imagesAndIcons/contact-us.webp"}}" alt="{{t "Spaziocrypto astronaut"}}" loading="lazy" decoding="async">
                            <div class="sc-contact-direct-card">
                                <h3>{{t "Prefer a Direct Approach?"}}</h3>
                                <ul>
                                    <li><a href="mailto:info@spaziocrypto.com">info@spaziocrypto.com</a></li>
                                    <li><a href="mailto:marketing@spaziocrypto.com">marketing@spaziocrypto.com</a></li>
                                    <li><a href="tel:+4407400250775">+44 07400250775</a></li>
                                </ul>
                                <h4>{{t "Visit Our Office"}}</h4>
                                <p>Galton Tower, 22, Civic Close, B1 2NW Birmingham</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>