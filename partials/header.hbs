<header class="gh-header gh-container header-{{#match @custom.header_type "Logo on the left"}}left-logo{{else match
    @custom.header_type "Author on the left" }}left-logo{{else match @custom.header_type "Logo in the middle"
    }}middle-logo{{else match @custom.header_type "Author in the middle" }}middle-logo{{else match
    @custom.header_type "Logo with social icons" }}include-social-icons{{else match
    @custom.header_type "Author with social icons" }}include-social-icons{{else match
    @custom.header_type "Mobile menu with logo" }}mobile-menu{{else match @custom.header_type "Mobile menu with author"
    }}mobile-menu{{else match @custom.header_type "Mobile menu with logo and icons" }}mobile-menu-icons{{else match
    @custom.header_type "Mobile menu with author and icons" }}mobile-menu-icons{{else match
    @custom.header_type "Logo with bottom navigation" }}bottom-nav{{else match
    @custom.header_type "Author with bottom navigation" }}bottom-nav{{/match}}{{#is 'post' }}{{#post}}{{#if featured}}
    transparent fixed{{/if}}{{/post}}{{/is}}{{#is 'page' }}{{#page}}{{#if featured}}{{#if feature_image}}{{#match @page.show_title_and_feature_image}}
    transparent fixed{{/match}}{{/if}}{{/if}}{{/page}}{{/is}}{{#is 'home' }}{{#match @custom.featured_posts "Large Slider" }} transparent
    fixed{{/match}}{{/is}}{{#is "home"}}{{else}} sc-header-jobs-layout{{/is}}" id="gh-header">
    <div class="gh-header-container">
        {{#match @custom.header_type "Logo with bottom navigation" }}
        <div class="gh-header-socials">
            {{>socials}}
        </div>
        {{else match @custom.header_type "Author with bottom navigation" }}
        <div class="gh-header-socials">
            {{>socials}}
        </div>
        {{/match}}
        <div class="gh-header-brand-wrapper">
            <button class="gh-burger-btn" aria-label="{{t "Mobile menu button"}}">
                {{>icons/burger-icon}}
            </button>
            <div class="gh-header-brand">
                {{#match @custom.header_type "Author on the left"}}
                {{>header-author}}
                {{else match @custom.header_type "Author in the middle"}}
                {{>header-author}}
                {{else match @custom.header_type "Author with social icons"}}
                {{>header-author}}
                {{else match @custom.header_type "Mobile menu with author and icons"}}
                {{>header-author}}
                {{else match @custom.header_type "Mobile menu with author"}}
                {{>header-author}}
                {{else match @custom.header_type "Author with bottom navigation"}}
                {{>header-author}}
                {{else}}
                <a class="gh-site-logo gh-site-logo-has-DM-logo"
                    href="{{@site.url}}" aria-label="{{@site.title}} {{t "logo and home page link"}}">
                    {{#if @site.logo}}
                    <img src="{{img_url @site.logo}}" alt="{{@site.title}} {{t "icon"}}" class="gh-site-logo-img" />
                    <img src="{{asset "imagesAndIcons/dark-logo.svg"}}" alt="{{@site.title}} {{t "icon"}}" class="gh-site-logo-img-dark-mode" />
                    {{else}}
                    <span class="gh-site-title">
                        <img class="gh-site-title-logo--dark" src="{{asset 'imagesAndIcons/dark-logo.svg'}}" alt="{{@site.title}}" />
                        <img class="gh-site-title-logo--light" src="{{asset 'imagesAndIcons/header-light.svg'}}" alt="{{@site.title}}" />
                    </span>
                    {{/if}}
                </a>
                {{/match}}
            </div>

        </div>
        {{#is "home"}}
        {{> "header-default-nav-row"}}
    </div>
        {{else}}
        <div class="gh-header-jobs-search-wrap">
            <button type="button" class="gh-header-jobs-search-btn" data-ghost-search aria-label="{{t "Search button"}}">
                <span class="gh-header-jobs-search-icon" aria-hidden="true">{{>icons/search}}</span>
                <span class="gh-header-jobs-search-placeholder">Search...</span>
                </button>
            </div>
        <div class="gh-header-actions gh-header-actions--jobs-top">
            <div class="sc-header-cta">
                <a class="sc-btn-outline" href="{{@site.url}}/post-a-job" aria-label="{{t "Post a Job"}}">
                    {{t "Post a Job"}}
                </a>
                <a class="sc-btn-filled" href="{{@site.url}}/list-your-company" aria-label="{{t "List Your Company"}}">
                    {{t "List Your Company"}}
                </a>
            </div>
        </div>
    </div>
    <div class="gh-header-container gh-header-jobs-subrow">
        {{> "header-main-nav"}}
        <div class="gh-header-actions gh-header-actions--jobs-bottom">
            {{> "header-actions-buttons"}}
        </div>
    </div>
        {{/is}}
    {{#match @custom.header_type "Logo with bottom navigation" }}
    <div class="gh-header-bottom gh-container">
        <div class="gh-header-bottom-navigation">
            {{navigation}}
        </div>
        <div class="gh-header-bottom-actions">
            
                <button class="popup-launcher no-mobile">
                    {{> "langswitch"}}
                </button>

            <button class="gh-dark-mode-toggle-btn" aria-label="{{t "Dark mode toggle button"}}">
                {{>icons/sun}}
                {{>icons/moon}}
            </button>
            <button class="gh-search-btn" title="{{t "Search button"}}" aria-label="{{t "Search button"}}" data-ghost-search>
                {{> "icons/search"}}
            </button>
        </div>
    </div>
    {{else match @custom.header_type "Author with bottom navigation" }}
    <div class="gh-header-bottom gh-container">
        <div class="gh-header-bottom-navigation">
            {{navigation}}
        </div>
        <div class="gh-header-bottom-actions">
            <button class="gh-dark-mode-toggle-btn" aria-label="{{t "Dark mode toggle button"}}">
                {{>icons/sun}}
                {{>icons/moon}}
            </button>
            <button class="gh-search-btn" title="Search button" aria-label="{{t "Search button"}}" data-ghost-search>
                {{> "icons/search"}}
            </button>
        </div>
    </div>
    {{/match}}
    {{> "mobile-menu"}}
</header>