{{!--Re-usable Card for Linking to Posts--}}

<article class="gh-card {{post_class}}{{#is "post"}} gh-read-next-card{{/is}}{{#match @custom.archive_type "List" }} list-card{{/match}}">
    <div class="gh-card-image-video-outer">
        <div class="gh-card-img-video-wrapper">
            {{#if feature_image}}
            <a class="gh-card-image-wrapper-link" href="{{url}}" aria-label="{{title}} {{t "post link"}}">
                <picture>
                <img src="{{img_url feature_image size="2000" }}" alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}" class="gh-card-image" />
                </picture>
            </a>
            {{else}}
            <a class="gh-card-image-wrapper-link--noImage" href="{{url}}" aria-label="{{title}} {{t "post link"}}">
                {{#if @site.logo}}
                    {{#if @custom.dark_mode_logo}}
                        <img src="{{img_url @custom.dark_mode_logo}}" alt="{{@site.title}} {{t "icon"}}" class="gh-card-image-wrapper-link--noImage__logo-dark">
                    {{/if}}
                        <img src="{{img_url @site.logo}}" alt="{{@site.title}} {{t "icon"}}" class="gh-card-image-wrapper-link--noImage__logo">
                {{else}}
                    <span class="gh-card-image-wrapper-link--noImage__name">{{@site.title}}</span>
                {{/if}}
            </a>
            {{/if}}
            {{#has tag="#video"}}
                <div class="gh-card-video-wrapper">
                    {{content}}
                </div>
                 <a class="gh-card-video-link" href="{{url}}" aria-label="{{title}} {{t "post link"}}"></a>
            {{/has}}
        </div>
    </div>
    <div class="gh-card-content">
        <div class="gh-card-content-main">
            <div class="gh-card-meta">

                {{#is "tag"}}
                {{#foreach tags visibility="all"}}
                    {{#has slug="hash-beginner"}}
                        <a class="filter-tag gh-tag" href="#" aria-label="{{name}} {{t "tag link"}}">
                            {{> 'icons/dot' }} {{#if meta_title}}{{meta_title}}{{else}}{{name}}{{/if}}
                        </a>
                    {{else}}
                        {{#has slug="hash-intermediate"}}
                            <a class="filter-tag gh-tag" href="#" aria-label="{{name}} {{t "tag link"}}">
                                {{> 'icons/dot' }} {{#if meta_title}}{{meta_title}}{{else}}{{name}}{{/if}}
                            </a>
                        {{else}}
                            {{#has slug="hash-advanced"}}
                                <a class="filter-tag gh-tag" href="#" aria-label="{{name}} {{t "tag link"}}">
                                    {{> 'icons/dot' }} {{#if meta_title}}{{meta_title}}{{else}}{{name}}{{/if}}
                                </a>
                            {{/has}}
                        {{/has}}
                    {{/has}}
                {{/foreach}}

                {{/is}}

                {{#if authors}}
                <div class="gh-card-authors">
                    <span>{{t "By"}}</span>
                    {{#primary_author}}
                    <a class="gh-card-author" href="{{url}}">{{name}}</a>
                    {{/primary_author}}
                </div>
                {{/if}}
                <span class="gh-card-date">
                    <time datetime="{{date format=" YYYY-MM-DD"}}">{{date format="MMM D, YYYY"}}</time>
                </span>

            </div>
            <h2 class="gh-card-title">
                <a class="gh-card-title-link" href="{{url}}" aria-label="{{title}} {{t "post link"}}">
                    {{title}}
                </a>
            </h2>
            {{#if excerpt}}
            <p class="gh-card-excerpt">{{excerpt}}</p>
            {{/if}}
        </div>
        <div class="gh-card-tags">{{#if featured}}
            <div class="gh-tag-icon featured-tag" role="note" aria-label="{{t "Featured post tag"}}">
                {{> 'icons/lightning'}}
            </div>
            {{/if}}
            {{^match visibility 'public'}}
            <div class="gh-tag-icon private-tag" role="note" aria-label="{{t "Private post tag"}}">
                {{> 'icons/lock-small'}}
            </div>
            {{/match}}

            {{#foreach tags}}
                {{#has slug="beginner"}}
                {{else}}
                    {{#has slug="intermediate"}}
                    {{else}}
                        {{#has slug="advanced"}}
                        {{else}}
                            <a class="gh-tag {{#if accent_color}} gh-tag-accent {{/if}}" 
                            {{#if accent_color}} 
                                style="--accent: {{accent_color}}; 
                                        background: color-mix(in srgb, {{accent_color}} 80%, transparent); 
                                        " 
                            {{/if}} 
                            href="{{url}}" 
                            aria-label="{{name}} {{t "tag link"}}">
                            {{name}}
                            </a>
                            
                        {{/has}}
                    {{/has}}
                {{/has}}
            {{/foreach}}
            
            
            </div>
    </div>
</article>