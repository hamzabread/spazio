            {{!-- Promote Your Event --}}
            <div class="sc-ta-card">
                <div class="sc-ta-card-icon sc-ta-card-icon--purple">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <rect x="3" y="4" width="18" height="18" rx="2"/>
