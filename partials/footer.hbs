<footer class="gh-footer scf-footer">
    <div class="scf-wrap gh-container">
        <div class="scf-top">
            <div class="scf-brand-col">
                <a class="scf-logo {{#if @custom.dark_mode_logo}}gh-site-logo-has-DM-logo{{/if}}" href="{{@site.url}}" aria-label="{{@site.title}} home">
                    <img src="{{asset "imagesAndIcons/Spaziocrypto-logo-a-filo-new 1.svg"}}" alt="{{@site.title}}" class="gh-site-logo-img scf-site-title-icon">
                    {{#if @custom.dark_mode_logo}}
                    <img src="{{img_url @custom.dark_mode_logo}}" alt="{{@site.title}}" class="gh-site-logo-img-dark-mode">
                    {{/if}}
                </a>

                <h3 class="scf-intel-title"><i class="fa fa-envelope" aria-hidden="true"></i> {{t "Daily Crypto Intel + Market News"}}</h3>
                <p class="scf-intel-sub">{{t "Get the latest crypto news and market analysis straight to your inbox."}}</p>

                <form class="gh-form scf-inline-form" data-members-form="subscribe" data-members-autoredirect="false" novalidate>
                    <div class="gh-form__input-wrapper">
                        <input class="gh-form-input scf-email-input" data-members-email type="email" name="email-input" placeholder="{{t "Your email address"}}" aria-label="{{t "Your email address"}}" required="true">
                    </div>
                    <button class="gh-main-button gh-form__submit-button scf-subscribe-btn" type="submit" aria-label="{{t "Subscribe"}}">
                        <span>{{t "Subscribe"}}</span>
                        {{> "icons/loader"}}
                    </button>
                    <p class="gh-form__error" data-members-error></p>
                </form>

                <p class="scf-note">{{t "No Spam. Unsubscribe Anytime."}}</p>

                <h4 class="scf-connect-title">{{t "CONNECT"}}</h4>
                <div class="scf-socials">
                    {{#if @site.facebook}}
                    <a href="{{facebook_url}}" target="_blank" rel="noopener noreferrer" aria-label="Facebook"><i class="fa fa-facebook" aria-hidden="true"></i></a>
                    {{/if}}
                    {{#if @custom.telegram_link}}
                    <a href="{{@custom.telegram_link}}" target="_blank" rel="noopener noreferrer" aria-label="Telegram"><i class="fa fa-paper-plane" aria-hidden="true"></i></a>
                    {{/if}}
                    {{#if @custom.google_news_link}}
                    <a href="{{@custom.google_news_link}}" target="_blank" rel="noopener noreferrer" aria-label="Google"><i class="fa fa-google" aria-hidden="true"></i></a>
                    {{/if}}
                    {{#if @custom.insta_link}}
                    <a href="{{@custom.insta_link}}" target="_blank" rel="noopener noreferrer" aria-label="Instagram"><i class="fa fa-instagram" aria-hidden="true"></i></a>
                    {{/if}}
                    {{#if @site.twitter}}
                    <a href="{{twitter_url}}" target="_blank" rel="noopener noreferrer" aria-label="X">X</a>
                    {{/if}}
                    {{#if @custom.linkedin_link}}
                    <a href="{{@custom.linkedin_link}}" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn"><i class="fa fa-linkedin" aria-hidden="true"></i></a>
                    {{/if}}
                    {{#if @custom.tiktok_link}}
                    <a href="{{@custom.tiktok_link}}" target="_blank" rel="noopener noreferrer" aria-label="TikTok"><i class="fa fa-music" aria-hidden="true"></i></a>
                    {{/if}}
                    {{#if @custom.reddit_link}}
                    <a href="{{@custom.reddit_link}}" target="_blank" rel="noopener noreferrer" aria-label="Reddit"><i class="fa fa-reddit-alien" aria-hidden="true"></i></a>
                    {{/if}}
                </div>
            </div>

            <div class="scf-links-col">
                <div class="scf-links-left">
                    <div class="scf-col">
                        <h5>{{t "Cryptocurrencies"}}</h5>
                        <a href="{{@site.url}}/tag/markets/">{{t "Coin Rankings"}}</a>
                        <a href="{{@site.url}}/tag/gainers/">{{t "Biggest Gainers"}}</a>
                        <a href="{{@site.url}}/tag/losers/">{{t "Biggest Losers"}}</a>
                        <a href="{{@site.url}}/tag/volume/">{{t "Highest Volume"}}</a>
                        <a href="{{@site.url}}/tag/new-listings/">{{t "Recently Added"}}</a>
                    </div>

                    <div class="scf-col">
                        <h5>{{t "Popular Sectors"}}</h5>
                        <a href="{{@site.url}}/tag/sectors/">{{t "Sectors Hub"}}</a>
                        <a href="{{@site.url}}/tag/ai/">{{t "AI"}}</a>
                        <a href="{{@site.url}}/tag/defi/">{{t "DeFi"}}</a>
                        <a href="{{@site.url}}/tag/memes/">{{t "Memes"}}</a>
                        <a href="{{@site.url}}/tag/stablecoins/">{{t "Stablecoins"}}</a>
                    </div>

                    <div class="scf-trending-sectors">
                        <h6>{{t "TRENDING SECTORS"}}</h6>
                        <div class="scf-chip-grid">
                            {{#get "tags" limit="10" order="count.posts desc"}}
                                {{#foreach tags}}
                                <a href="{{url}}"><span>{{name}} ({{count.posts}})</span></a>
                                {{/foreach}}
                            {{/get}}
                        </div>
                    </div>
                </div>

                <div class="scf-links-right">
                    <div class="scf-col">
                        <h5>{{t "Crypto News"}}</h5>
                        <a href="{{@site.url}}/tag/bitcoin/">{{t "Bitcoin"}}</a>
                        <a href="{{@site.url}}/tag/ethereum/">{{t "Ethereum"}}</a>
                        <a href="{{@site.url}}/tag/ripple/">{{t "Ripple"}}</a>
                        <a href="{{@site.url}}/tag/altcoins/">{{t "Altcoins"}}</a>

                        <h5 class="scf-subhead">{{t "News Coverage"}}</h5>
                        <a href="{{@site.url}}/tag/defi/">{{t "DeFi"}}</a>
                        <a href="{{@site.url}}/tag/macro/">{{t "Macro"}}</a>
                        <a href="{{@site.url}}/tag/markets/">{{t "Markets"}}</a>
                        <a href="{{@site.url}}/tag/politics/">{{t "Politics"}}</a>
                        <a href="{{@site.url}}/tag/regulation/">{{t "Regulation"}}</a>
                    </div>

                    <div class="scf-col">
                        <h5>{{t "Reviews"}}</h5>
                        <a href="{{@site.url}}/tag/reviews/">{{t "Reviews Hub"}}</a>
                        <a href="{{@site.url}}/tag/bitcoin-ira/">{{t "Bitcoin IRA"}}</a>
                        <a href="{{@site.url}}/tag/exchanges/">{{t "Crypto Exchanges"}}</a>
                        <a href="{{@site.url}}/tag/crypto-casinos/">{{t "Crypto Casinos"}}</a>

                        <h5 class="scf-subhead">{{t "Directory"}}</h5>
                        <a href="{{@site.url}}/directory/">{{t "Directory Hub"}}</a>
                        <a href="{{@site.url}}/tag/companies/">{{t "Companies"}}</a>
                        <a href="{{@site.url}}/tag/products/">{{t "Products"}}</a>
                        <a href="{{@site.url}}/tag/people/">{{t "People"}}</a>
                    </div>

                    <div class="scf-col">
                        <h5>{{t "More"}}</h5>
                        <a href="{{@site.url}}/about-us/">{{t "About SpazioCrypto"}}</a>
                        <a href="{{@site.url}}/brand-assets/">{{t "Brand Assets"}}</a>
                        <a href="{{@site.url}}/tag/company-updates/">{{t "Company Updates"}}</a>
                        <a href="{{@site.url}}/glossary/">{{t "Crypto Glossary"}}</a>
                        <a href="{{@site.url}}/disclaimers/">{{t "Disclaimers"}}</a>
                        <a href="{{@site.url}}/faq/">{{t "FAQ"}}</a>
                        <a href="{{@site.url}}/help/">{{t "Help & Support"}}</a>
                        <a href="{{@site.url}}/media-kit/">{{t "Media Kit"}}</a>
                        <a href="{{@site.url}}/tag/press-release/">{{t "Press Releases"}}</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="scf-disclaimer">
            {{t "Disclaimer: By using this website, you agree to the Terms and Conditions and Privacy Policy. SpazioCrypto has no affiliation or relationship with any coin, business, project or event unless explicitly noted otherwise. SpazioCrypto is only an informational website that provides news about coins, blockchain companies, blockchain products and events. None of the information you read on SpazioCrypto should be taken as investment advice. Buying crypto currencies should be considered a high-risk investment. Please do your own diligence before making any investment decisions. SpazioCrypto will not be held responsible, directly or indirectly, for any damage or loss caused or alleged to be caused by or in connection with the use of or reliance on any content you read on the site."}}
        </div>

        <div class="scf-bottom">
            <span>© {{date format="YYYY"}} SpazioCrypto. All rights reserved.</span>
            <a href="/terms-and-conditions">Terms &amp; Conditions</a>
            <span>|</span>
            <a href="/privacy-and-cookie-policy">Privacy Policy</a>
        </div>
    </div>
</footer>
