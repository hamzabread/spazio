{{#has tag="#glossary"}}
<style>
    html {
        scroll-behavior: smooth;
    }
    .gh-glossary-index{
        display: flex;
        justify-content: center;
        margin-bottom: 20px;
        gap:1rem;
        flex-wrap: wrap;
        position: sticky;
        top: 0;
        background: var(--color-background-main);
        padding: 1rem 1.5rem;
        z-index: 1000;
    }
    .gh-glossary-group{
        padding: 0 20px;
        width: 100%;
        max-width: 784px;
        box-shadow: none;
        border-radius: var(--border-radius-containers);
        transition: background-color 0.25s ease;
        scroll-margin-top: 60px;
    }
    .gh-post-content .gh-glossary-item:last-child {
        margin-bottom: 32px;
    }
    .gh-glossary-index-item{
        font-weight: bold;
        cursor: pointer;
    }
    .gh-glossary-index-item.disabled{
        pointer-events: none;
        color: #bbb;
    }
    .gh-post-content .gh-glossary-item > *:last-child {
        margin-bottom: 0 !important;
    }
    .gh-glossary-group > h2 {
        position: relative;
    }
    .gh-glossary-group > h2 span {
        display: inline-block;
        padding-right: 30px;
        position: relative;
        z-index: 1;
        background: var(--color-background-main);
        transition: color 0.3s ease;
    }
    .gh-glossary-group p {
        font-size: var(--font-size-body);
        font-weight: 400;
        line-height: 1.5;
        margin-bottom: 32px;
        width: 100%;
        max-width: 784px;
    }
    .gh-glossary-group > h2:after {
        content: '';
        display: block;
        width: 100%;
        height: 1px;
        position: absolute;
        left: 0;
        top: 50%;
        z-index: 0;
        background: #e6e6e6
    }

    /* Highlighted glossary letter */
    .gh-glossary-group > h2 span.active {
        color: var(--ghost-accent-color, var(--ghost-accent-color, #2E3690)); /* fallback if Ghost variable missing */
    }

    /* Highlighted index letter when section is in view */
    .gh-glossary-index-item.active {
        font-weight: bolder;
        transform: scale(1.3);
        transition: all 0.3s ease;
    }
</style>

<script>
    const glossayItemElements = document.querySelectorAll('.kg-card.kg-toggle-card');
    let glossaryItems = [];

    glossayItemElements.forEach((item) => {
        const title = item.querySelector('.kg-toggle-heading').textContent.trim();
        const description = item.querySelector('.kg-toggle-content').innerHTML;
        glossaryItems.push({
            title,
            description
        });
        //Hide element from the content
        item.style.display = 'none';
    });

    // Create an A - Z index element
    const glossaryIndex = document.createElement('div');
    glossaryIndex.classList.add('gh-glossary-index');
    document.querySelector('.gh-post-content').appendChild(glossaryIndex);
    
    const alphabet = 'abcdefghijklmnopqrstuvwxyz'.split('');
    alphabet.forEach((letter) => {
        const indexElement = document.createElement('a');
        indexElement.href = `#glossary-${letter}`;
        indexElement.textContent = letter.toUpperCase();
        indexElement.classList.add('gh-glossary-index-item');
        glossaryIndex.appendChild(indexElement);
    });

    // Create a glossary letter group for each letter
    alphabet.forEach((letter) => {
        const glossaryLetterGroup = document.createElement('div');
        glossaryLetterGroup.id = `glossary-${letter}`;
        glossaryLetterGroup.classList.add('gh-glossary-group');
        document.querySelector('.gh-post-content').appendChild(glossaryLetterGroup);

        const glossaryLetterGroupTitle = document.createElement('h2');
        glossaryLetterGroupTitle.innerHTML = `<span>${letter.toUpperCase()}</span>`;
        glossaryLetterGroup.appendChild(glossaryLetterGroupTitle);

        const glossaryLetterGroupList = document.createElement('div');
        glossaryLetterGroupList.classList.add('gh-glossary-group-content');
        glossaryLetterGroup.appendChild(glossaryLetterGroupList);

        glossaryItems.forEach((item) => {
            if (item.title.toLowerCase().startsWith(letter)) {
                const glossaryItem = document.createElement('div');
                glossaryItem.classList.add('gh-glossary-item');
                glossaryItem.innerHTML = `
                    <h5>${item.title}</h5>
                    <span>${item.description}</span>
                `;
                glossaryLetterGroupList.appendChild(glossaryItem);
            }
        });
    });

    // Remove empty glossary letter groups
    const glossaryGroups = document.querySelectorAll('.gh-glossary-group');
    glossaryGroups.forEach((group) => {
        if (group.querySelector('.gh-glossary-item') === null) {
            group.remove();
        }
    });

    // Disable index items with no glossary items
    const indexItems = document.querySelectorAll('.gh-glossary-index-item');
    indexItems.forEach((indexItem) => {
        const letter = indexItem.textContent.toLowerCase();
        const glossaryItemsForLetter = glossaryItems.filter((item) => item.title.toLowerCase().startsWith(letter));
        if (glossaryItemsForLetter.length === 0) {
            indexItem.classList.add('disabled');
        }
    });

    // Highlight corresponding glossary header span on click
    indexItems.forEach((indexItem) => {
        indexItem.addEventListener('click', (e) => {
            const letter = indexItem.textContent.toLowerCase();
            // Remove active class from all spans
            document.querySelectorAll('.gh-glossary-group > h2 span').forEach(span => {
                span.classList.remove('active');
            });
            // Add active class to the clicked glossary letter span
            const targetGroup = document.querySelector(`#glossary-${letter} > h2 span`);
            if (targetGroup) {
                targetGroup.classList.add('active');
            }
        });
    });

    // Intersection Observer to highlight index letters based on scroll position
    const observerOptions = {
        root: null,
        rootMargin: '-20% 0px -70% 0px', // Trigger when section is 20% from top
        threshold: 0
    };

    const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
            if (entry.isIntersecting) {
                const sectionId = entry.target.id;
                const letter = sectionId.replace('glossary-', '');
                
                // Remove active class from all index items
                document.querySelectorAll('.gh-glossary-index-item').forEach(item => {
                    item.classList.remove('active');
                });
                
                // Add active class to the corresponding index item
                const activeIndexItem = document.querySelector(`.gh-glossary-index-item[href="#${sectionId}"]`);
                if (activeIndexItem) {
                    activeIndexItem.classList.add('active');
                }

                // Also update the section header highlighting
                document.querySelectorAll('.gh-glossary-group > h2 span').forEach(span => {
                    span.classList.remove('active');
                });
                const targetSpan = document.querySelector(`#${sectionId} > h2 span`);
                if (targetSpan) {
                    targetSpan.classList.add('active');
                }
            }
        });
    }, observerOptions);

    // Observe all glossary groups
    document.querySelectorAll('.gh-glossary-group').forEach(group => {
        observer.observe(group);
    });
</script>
{{/has}}
