<section class="sc-jobs">
    <div class="sc-jobs-inner">
        <div class="sc-jobs-top">
            <h2 class="sc-jobs-title">{{t "Crypto Jobs"}}</h2>
            <div class="sc-jobs-controls">
                <div class="sc-jobs-search">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none">
                        <path d="M7.66732 14.0002C11.1651 14.0002 14.0007 11.1646 14.0007 7.66683C14.0007 4.16903 11.1651 1.3335 7.66732 1.3335C4.16951 1.3335 1.33398 4.16903 1.33398 7.66683C1.33398 11.1646 4.16951 14.0002 7.66732 14.0002Z" stroke="var(--color-muted-legacy)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        <path d="M14.6673 14.6668L13.334 13.3335" stroke="var(--color-muted-legacy)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    <input type="text" class="sc-jobs-search-input" placeholder="{{t "Search"}}" aria-label="{{t "Search jobs"}}">
                </div>
                <div class="sc-jobs-sort">
                    <span>{{t "Sort"}}</span>
                    <svg width="14" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 15l5 5 5-5M7 9l5-5 5 5"/></svg>
                </div>
                <button class="sc-jobs-filter-btn" aria-label="{{t "Filter"}}">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none">
                        <path d="M14.4193 9.83317C14.4193 10.4265 14.2593 10.9865 13.9659 11.4665C13.4193 12.3798 12.4126 12.9998 11.2526 12.9998C10.6259 12.9998 10.0393 12.8132 9.54594 12.4865C9.13261 12.2332 8.79261 11.8798 8.54594 11.4665C8.25261 10.9865 8.08594 10.4265 8.08594 9.83317C8.08594 8.0865 9.50594 6.6665 11.2526 6.6665C11.4926 6.6665 11.7259 6.69317 11.9459 6.7465C13.3659 7.05983 14.4193 8.3265 14.4193 9.83317Z" fill="#EBEFF2" stroke="#005F93" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/>
                        <path d="M10.0195 9.83323L10.7995 10.6132L12.4862 9.05322" fill="#EBEFF2"/>
                        <path d="M10.0195 9.83323L10.7995 10.6132L12.4862 9.05322" stroke="#005F93" stroke-linecap="round" stroke-linejoin="round"/>
                        <path d="M13.7937 2.68016V4.16016C13.7937 4.70016 13.4537 5.3735 13.1204 5.7135L11.947 6.74683C11.727 6.69349 11.4937 6.66683 11.2537 6.66683C9.50704 6.66683 8.08704 8.08683 8.08704 9.8335C8.08704 10.4268 8.2537 10.9868 8.54704 11.4668C8.7937 11.8802 9.1337 12.2335 9.54704 12.4868V12.7135C9.54704 13.1202 9.28035 13.6602 8.94035 13.8602L8.00037 14.4668C7.12703 15.0068 5.9137 14.4002 5.9137 13.3202V9.7535C5.9137 9.28017 5.64036 8.6735 5.3737 8.34017L2.81368 5.64683C2.48035 5.30683 2.20703 4.70017 2.20703 4.30017V2.74683C2.20703 1.94016 2.81371 1.3335 3.55371 1.3335H12.447C13.187 1.3335 13.7937 1.94016 13.7937 2.68016Z" stroke="#EBEFF2" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </button>
            </div>
        </div>

        <div class="sc-jobs-chips">
            {{#if @custom.jobs_source_tag}}
            <a class="sc-jobs-chip" href="{{@site.url}}/tag/{{@custom.jobs_source_tag}}/">{{t "All"}}</a>
            {{else}}
            <a class="sc-jobs-chip" href="{{@site.url}}/tag/jobs/">{{t "All"}}</a>
            {{/if}}
            <a class="sc-jobs-chip" href="{{@site.url}}/tag/exchanges/">{{t "Exchanges"}}</a>
            <a class="sc-jobs-chip" href="{{@site.url}}/tag/wallets/">{{t "Wallets"}}</a>
            <a class="sc-jobs-chip" href="{{@site.url}}/tag/analytics/">{{t "Analytics"}}</a>
            <a class="sc-jobs-chip" href="{{@site.url}}/tag/defi-apps/">{{t "DeFi Apps"}}</a>
            <a class="sc-jobs-chip" href="{{@site.url}}/tag/on-chain/">{{t "On-Chain"}}</a>
            <a class="sc-jobs-chip" href="{{@site.url}}/tag/ai/">{{t "AI"}}</a>
            <a class="sc-jobs-chip" href="{{@site.url}}/tag/nft/">{{t "NFT"}}</a>
            <a class="sc-jobs-chip" href="{{@site.url}}/tag/news/">{{t "News"}}</a>
            <a class="sc-jobs-chip" href="{{@site.url}}/tag/research/">{{t "Research"}}</a>
            <a class="sc-jobs-chip" href="{{@site.url}}/tag/launchpads/">{{t "Launchpads"}}</a>
        </div>

        <div class="sc-jobs-grid">
            {{#if @custom.jobs_source_filter}}
            {{#get "posts" filter=@custom.jobs_source_filter limit="6" include="authors,tags" order="published_at desc"}}
                {{#if posts}}
                    {{#foreach posts}}
                    {{> "job-card"}}
                    {{/foreach}}
                {{else}}
                    {{#get "posts" filter="tags:[jobs,careers,job,hiring]" limit="6" include="authors,tags" order="published_at desc"}}
                        {{#foreach posts}}
                        {{> "job-card"}}
                        {{/foreach}}
                    {{/get}}
                {{/if}}
            {{/get}}
            {{else}}
            {{#get "posts" filter="tags:[jobs,careers,job,hiring]" limit="6" include="authors,tags" order="published_at desc"}}
                {{#foreach posts}}
                {{> "job-card"}}
                {{/foreach}}
            {{/get}}
            {{/if}}
        </div>

        <div class="sc-jobs-load-more-wrap">
            <button class="sc-jobs-load-more-btn is-hidden" type="button">{{t "Load more"}}</button>
        </div>

        <div class="sc-jobs-cta">
            <div class="sc-jobs-cta-text">
                <h3>{{t "Post a Job Opening"}}</h3>
                <p>{{t "Find top talent in the crypto and blockchain space"}}</p>
            </div>
            {{#if @custom.jobs_source_tag}}
            <a class="sc-jobs-cta-btn" href="{{@site.url}}/tag/{{@custom.jobs_source_tag}}/">{{t "Post a Job"}}</a>
            {{else}}
            <a class="sc-jobs-cta-btn" href="{{@site.url}}/tag/jobs/">{{t "Post a Job"}}</a>
            {{/if}}
        </div>
    </div>
</section>
