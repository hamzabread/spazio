<section class="sc-hero">
    <div class="sc-hero-inner gh-container">
        <div class="sc-hero-floating-card sc-hero-card-btc">
            <div class="sc-hero-card-icon sc-hero-card-icon--btc">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="12" fill="#F7931A"/><path d="M16.66 10.49c.23-1.52-.93-2.34-2.51-2.89l.51-2.06-1.25-.31-.5 2c-.33-.08-.67-.16-1-.23l.5-2.01-1.25-.31-.51 2.06c-.27-.06-.54-.12-.8-.19l-1.73-.43-.33 1.33s.93.21.91.23c.51.13.6.46.58.73l-.59 2.35c.04.01.08.02.13.04l-.13-.03-.82 3.3c-.06.15-.22.39-.57.3.01.02-.91-.23-.91-.23l-.62 1.43 1.63.41c.3.08.6.15.89.23l-.52 2.08 1.25.31.51-2.06c.34.09.67.18 1 .26l-.51 2.05 1.25.31.52-2.07c2.13.4 3.73.24 4.4-1.69.54-1.55-.03-2.44-1.15-3.03.82-.19 1.43-.72 1.6-1.84zm-2.86 4.01c-.38 1.55-2.98.71-3.82.5l.68-2.74c.84.21 3.54.63 3.14 2.24zm.39-4.04c-.35 1.41-2.51.69-3.21.52l.62-2.48c.7.17 2.96.5 2.59 1.96z" fill="#fff"/></svg>
            </div>
            <div class="sc-hero-card-text">
                <span class="sc-hero-card-value">$94.2K</span>
                <span class="sc-hero-card-label">Bitcoin Price</span>
            </div>
        </div>

        <div class="sc-hero-floating-card sc-hero-card-articles">
            <div class="sc-hero-card-icon sc-hero-card-icon--articles">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
            </div>
            <div class="sc-hero-card-text">
                <span class="sc-hero-card-value">500+</span>
                <span class="sc-hero-card-label">{{t "Daily Articles"}}</span>
            </div>
        </div>

        <div class="sc-hero-content">
            <span class="sc-hero-badge">{{t "Your Complete Crypto Ecosystem"}}</span>
            <h1 class="sc-hero-title">
                {{t "Real-Time Crypto News,"}}<br>
                <span class="sc-hero-title-accent">{{t "Markets & Opportunities"}}</span>
            </h1>
            <p class="sc-hero-desc">
                {{t "SpazioCrypto is not just news—it's your complete platform for crypto intelligence, market data, job opportunities, and industry events."}}
            </p>
            <div class="sc-hero-stats">
                <div class="sc-hero-stat">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                    <span>600K+ {{t "Readers"}}</span>
                </div>
                <div class="sc-hero-stat">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                    <span>{{t "Available in 12 Languages"}}</span>
                </div>
                <div class="sc-hero-stat">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                    <span>{{t "Independent Editorial"}}</span>
                </div>
            </div>
        </div>

        <div class="sc-hero-floating-card sc-hero-card-mcap">
            <div class="sc-hero-card-icon sc-hero-card-icon--mcap">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="12" fill="#2563EB"/><path d="M12 6v12M8 10l4-4 4 4M8 14l4 4 4-4" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <div class="sc-hero-card-text">
                <span class="sc-hero-card-value">$2.1T</span>
                <span class="sc-hero-card-label">{{t "Market Cap"}}</span>
            </div>
        </div>

        <div class="sc-hero-floating-card sc-hero-card-change">
            <div class="sc-hero-card-icon sc-hero-card-icon--change">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
            </div>
            <div class="sc-hero-card-text">
                <span class="sc-hero-card-value sc-hero-card-value--green">+5.2%</span>
                <span class="sc-hero-card-label">{{t "24h Change"}}</span>
            </div>
        </div>
    </div>
</section>
