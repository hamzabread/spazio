{{#get "posts" include="tags" filter="tags:[scams,truffe,arnaques,estafas,betrug,moshennichestvo,sagi,pianju]" limit=10 as |scams|}}
{{#if scams}}
<div class="scam-news-section">
  <div class="header-bar">
    <div class="marquee-continuous">
      <div class="marquee-content">
        <span>{{t "SCAM ALERT"}} -</span>
        <span>{{t "SCAM ALERT"}} -</span>
        <span>{{t "SCAM ALERT"}} -</span>
        <span>{{t "SCAM ALERT"}} -</span>
        <span>{{t "SCAM ALERT"}} -</span>
        <span>{{t "SCAM ALERT"}} -</span>
        <span>{{t "SCAM ALERT"}} -</span>
        <span>{{t "SCAM ALERT"}} -</span>
        <span>{{t "SCAM ALERT"}} -</span>
        <span>{{t "SCAM ALERT"}} -</span>
        <span>{{t "SCAM ALERT"}} -</span>
      </div>
    </div>
  </div>
  <div class="news-list">
    <!-- News items remain the same as before -->
    {{#foreach scams}}
    <div class="news-item">
      <div class="dot-line"></div>
      {{#primary_tag}}
        <a class="gh-tag {{#if accent_color}} gh-tag-accent {{/if}}" {{#if accent_color}} style="--accent: {{accent_color}}; background: color-mix(in srgb, {{accent_color}} 80%, transparent);"{{/if}}  href="{{url}}" aria-label="Blockchain tag link">{{name}}</a>
      {{/primary_tag}}
      <span class="date"><time  datetime="{{date format='YYYY-MM-DDTHH:mm:ss'}}Z">{{date format='MMM D, YYYY HH:mm:ss'}} UTC</time></span>
      
      <h4 class="gh-sidebar-feat-post-title">
            <a href="{{url}}">{{title}}</a>
        </h4>
      <p class="description">
        {{excerpt }}
      </p>
      <a href="{{url}}" class="read-more">{{t "Read More"}}</a>
    </div>
    {{/foreach}}
  </div>
  {{#get "tags" filter="slug:[scams,truffe,arnaques,estafas,betrug,moshennichestvo,sagi,pianju]" limit=1 as |button_link|}}
{{#button_link}}
  <a class="gh-main-button gh-sidebar-cta-btn" href="{{url}}" aria-label="View all scams">
    {{t "View all Scams"}}
  </a>
  {{/button_link}}
{{/get}}
</div>
{{/if}}
  {{/get}}
