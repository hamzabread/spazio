<div class="gh-header-actions-buttons">


     <div class="popup-launcher no-mobile" role="navigation" aria-label="{{t "Switch language"}}">
        {{> "langswitch"}}
              <span class="caret"><svg xmlns="http://www.w3.org/2000/svg" width="7" height="4" viewBox="0 0 7 4" fill="none"><path d="M0.5 0.5L3.5 3.5L6.5 0.5" stroke="white" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
     </div>


    <button class="gh-dark-mode-toggle-btn" aria-label="{{t "Dark mode toggle button"}}">
        {{>icons/sun}}
        {{>icons/moon}}
    </button>
    <script>
        const toggleBtn = document.querySelector(".gh-dark-mode-toggle-btn");

            function updateTooltip(isDarkMode) {
            toggleBtn.setAttribute(
                "data-tooltip",
                isDarkMode ? "Switch to Light Mode" : "Switch to Dark Mode"
            );
            }

            let darkMode = false;
            toggleBtn.addEventListener("click", () => {
            darkMode = !darkMode;
            updateTooltip(darkMode);
            });

            updateTooltip(darkMode);

    </script>
    <button class="gh-search-btn" title="{{t "Search button"}}" aria-label="{{t "Search button"}}" data-ghost-search>
        {{>icons/search}}
    </button>
</div>
