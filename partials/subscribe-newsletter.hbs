<section class="sc-newsletter-section">
    <div class="sc-newsletter-wrap">
        <div class="sc-newsletter-panel">
            <h2 class="sc-newsletter-title">SUBSCRIBE TO THE NEWSLETTER</h2>
            <p class="sc-newsletter-subtitle">Spaziocrypto brings you weekly summary of major Web-3 related news.</p>

            <form class="sc-newsletter-form" action="#/portal/signup" method="get">
                <input class="sc-newsletter-input" type="text" name="name" placeholder="Full Name" aria-label="Full Name" />
                <input class="sc-newsletter-input" type="email" name="email" placeholder="Your Email Address" aria-label="Your Email Address" />
                <button class="sc-newsletter-btn" type="submit">Subscribe</button>
            </form>
        </div>
    </div>
</section>
