<section class="sc-about-faq">
    <div class="sc-about-shell">
        <div class="sc-about-faq-wrap">
            <div class="sc-about-faq-head">
                <h3>Frequently Asked <span>Questions</span></h3>
                <p data-sc-about-faq-intro>Clear answers to the most common questions about our work, policies, and editorial standards.</p>
            </div>

            <div class="sc-about-faq-list" data-faq-list>
                <article class="sc-about-faq-item is-open" data-faq-item>
                    <button class="sc-about-faq-trigger" type="button" aria-expanded="true">
                        <span class="sc-about-faq-question">How do you choose advertisers and partners?</span>
                        <span class="sc-about-faq-icon sc-about-faq-icon-closed" aria-hidden="true">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                                <path d="M12 8V16M8 12H16M22 12C22 17.5228 17.5228 22 12 22C6.47715 22 2 17.5228 2 12C2 6.47715 6.47715 2 12 2C17.5228 2 22 6.47715 22 12Z" stroke="#EBEFF2" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </span>
                        <span class="sc-about-faq-icon sc-about-faq-icon-open" aria-hidden="true">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                                <path d="M8 12H16M22 12C22 17.5228 17.5228 22 12 22C6.47715 22 2 17.5228 2 12C2 6.47715 6.47715 2 12 2C17.5228 2 22 6.47715 22 12Z" stroke="#EBEFF2" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </span>
                    </button>
                    <div class="sc-about-faq-answer-wrap" data-faq-answer-wrap>
                        <p class="sc-about-faq-answer">We collaborate only with verified companies that meet our standards for quality, transparency, and legitimacy.</p>
                    </div>
                </article>

                <article class="sc-about-faq-item" data-faq-item>
                    <button class="sc-about-faq-trigger" type="button" aria-expanded="false">
                        <span class="sc-about-faq-question">How can I tell if content is sponsored?</span>
                        <span class="sc-about-faq-icon sc-about-faq-icon-closed" aria-hidden="true">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                                <path d="M12 8V16M8 12H16M22 12C22 17.5228 17.5228 22 12 22C6.47715 22 2 17.5228 2 12C2 6.47715 6.47715 2 12 2C17.5228 2 22 6.47715 22 12Z" stroke="#EBEFF2" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </span>
                        <span class="sc-about-faq-icon sc-about-faq-icon-open" aria-hidden="true">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                                <path d="M8 12H16M22 12C22 17.5228 17.5228 22 12 22C6.47715 22 2 17.5228 2 12C2 6.47715 6.47715 2 12 2C17.5228 2 22 6.47715 22 12Z" stroke="#EBEFF2" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </span>
                    </button>
                    <div class="sc-about-faq-answer-wrap" data-faq-answer-wrap>
                        <p class="sc-about-faq-answer">Sponsored content is always clearly labeled to distinguish it from editorial articles and research pieces.</p>
                    </div>
                </article>

                <article class="sc-about-faq-item" data-faq-item>
                    <button class="sc-about-faq-trigger" type="button" aria-expanded="false">
                        <span class="sc-about-faq-question">Do you provide financial advice?</span>
                        <span class="sc-about-faq-icon sc-about-faq-icon-closed" aria-hidden="true">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                                <path d="M12 8V16M8 12H16M22 12C22 17.5228 17.5228 22 12 22C6.47715 22 2 17.5228 2 12C2 6.47715 6.47715 2 12 2C17.5228 2 22 6.47715 22 12Z" stroke="#EBEFF2" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </span>
                        <span class="sc-about-faq-icon sc-about-faq-icon-open" aria-hidden="true">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                                <path d="M8 12H16M22 12C22 17.5228 17.5228 22 12 22C6.47715 22 2 17.5228 2 12C2 6.47715 6.47715 2 12 2C17.5228 2 22 6.47715 22 12Z" stroke="#EBEFF2" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </span>
                    </button>
                    <div class="sc-about-faq-answer-wrap" data-faq-answer-wrap>
                        <p class="sc-about-faq-answer">No. We provide educational and informational content only and encourage readers to do their own research.</p>
                    </div>
                </article>

                <article class="sc-about-faq-item" data-faq-item>
                    <button class="sc-about-faq-trigger" type="button" aria-expanded="false">
                        <span class="sc-about-faq-question">How can I participate in events and seminars?</span>
                        <span class="sc-about-faq-icon sc-about-faq-icon-closed" aria-hidden="true">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                                <path d="M12 8V16M8 12H16M22 12C22 17.5228 17.5228 22 12 22C6.47715 22 2 17.5228 2 12C2 6.47715 6.47715 2 12 2C17.5228 2 22 6.47715 22 12Z" stroke="#EBEFF2" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </span>
                        <span class="sc-about-faq-icon sc-about-faq-icon-open" aria-hidden="true">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                                <path d="M8 12H16M22 12C22 17.5228 17.5228 22 12 22C6.47715 22 2 17.5228 2 12C2 6.47715 6.47715 2 12 2C17.5228 2 22 6.47715 22 12Z" stroke="#EBEFF2" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </span>
                    </button>
                    <div class="sc-about-faq-answer-wrap" data-faq-answer-wrap>
                        <p class="sc-about-faq-answer">You can follow our announcements and registration links on the website and social channels for upcoming events.</p>
                    </div>
                </article>

                <article class="sc-about-faq-item" data-faq-item>
                    <button class="sc-about-faq-trigger" type="button" aria-expanded="false">
                        <span class="sc-about-faq-question">How do I contact the team?</span>
                        <span class="sc-about-faq-icon sc-about-faq-icon-closed" aria-hidden="true">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                                <path d="M12 8V16M8 12H16M22 12C22 17.5228 17.5228 22 12 22C6.47715 22 2 17.5228 2 12C2 6.47715 6.47715 2 12 2C17.5228 2 22 6.47715 22 12Z" stroke="#EBEFF2" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </span>
                        <span class="sc-about-faq-icon sc-about-faq-icon-open" aria-hidden="true">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                                <path d="M8 12H16M22 12C22 17.5228 17.5228 22 12 22C6.47715 22 2 17.5228 2 12C2 6.47715 6.47715 2 12 2C17.5228 2 22 6.47715 22 12Z" stroke="#EBEFF2" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </span>
                    </button>
                    <div class="sc-about-faq-answer-wrap" data-faq-answer-wrap>
                        <p class="sc-about-faq-answer">Use our contact page or official social channels and we will route your message to the right team member.</p>
                    </div>
                </article>
            </div>
        </div>
    </div>
</section>

<script>
    (function () {
        var faqItems = document.querySelectorAll('[data-faq-item]');
        if (!faqItems.length) return;

        function setOpenState(item, isOpen) {
            var trigger = item.querySelector('.sc-about-faq-trigger');
            var panel = item.querySelector('[data-faq-answer-wrap]');
            if (!trigger || !panel) return;

            trigger.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
            item.classList.toggle('is-open', isOpen);

            if (isOpen) {
                panel.style.maxHeight = panel.scrollHeight + 'px';
            } else {
                panel.style.maxHeight = '0px';
            }
        }

        faqItems.forEach(function (item) {
            var trigger = item.querySelector('.sc-about-faq-trigger');
            var panel = item.querySelector('[data-faq-answer-wrap]');
            if (!trigger || !panel) return;

            if (item.classList.contains('is-open')) {
                panel.style.maxHeight = panel.scrollHeight + 'px';
            } else {
                panel.style.maxHeight = '0px';
            }

            trigger.addEventListener('click', function () {
                var isOpen = item.classList.contains('is-open');

                faqItems.forEach(function (other) {
                    if (other !== item) {
                        setOpenState(other, false);
                    }
                });

                setOpenState(item, !isOpen);
            });
        });

        window.addEventListener('resize', function () {
            faqItems.forEach(function (item) {
                if (item.classList.contains('is-open')) {
                    var panel = item.querySelector('[data-faq-answer-wrap]');
                    if (panel) panel.style.maxHeight = panel.scrollHeight + 'px';
                }
            });
        });
    })();
</script>