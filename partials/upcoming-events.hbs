        <div class="sc-trusted-by">
            <p class="sc-trusted-label">{{t "Trusted by leading crypto platforms"}}</p>
            <div class="sc-trusted-logos sc-trusted-logos--marquee">
                <div class="sc-trusted-logos-viewport">
                    <div class="sc-trusted-logos-track">
                        <div class="sc-trusted-logos-group">
                            {{> "trusted-logos-row"}}
                        </div>
                        <div class="sc-trusted-logos-group" aria-hidden="true">
