<section class="sc-content-grid">

    {{!-- Left Column: Crypto Market --}}
    <div class="sc-content-grid-left">
        <div class="sc-market-card">
            <div class="sc-market-header">
                <span>{{t "Crypto Market"}}</span>
                <a href="{{@site.url}}/tag/markets/" aria-label="{{t "View all markets"}}">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 14 14" fill="none">
                        <path d="M7.11588 2.91699L11.1992 7.00033L7.11588 11.0837" stroke="#F18F20" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                        <path d="M3.03255 7L11.1992 7" stroke="#F18F20" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </a>
            </div>
            <div class="sc-market-list">
                <a class="sc-market-item" href="https://www.coingecko.com/en/coins/bitcoin" aria-label="Bitcoin" data-market-row="bitcoin" target="_blank" rel="noopener">
                    <img class="sc-market-coin-icon" src="{{asset "imagesAndIcons/bitcoin.svg"}}" alt="Bitcoin" loading="lazy" width="48" height="48" data-market-icon>
                    <div class="sc-market-coin-info">
                        <span class="sc-market-coin-name" data-market-name>Bitcoin</span>
                        <span class="sc-market-coin-symbol" data-market-symbol>BTC</span>
                    </div>
                    <div class="sc-market-coin-price">
                        <span class="sc-market-coin-price-value" data-market-price>$93,041.34</span>
                        <span class="sc-market-coin-change sc-md-change-up" data-market-change>↑2.04%</span>
                    </div>
                </a>
                <a class="sc-market-item" href="https://www.coingecko.com/en/coins/ethereum" aria-label="Ethereum" data-market-row="ethereum" target="_blank" rel="noopener">
                    <img class="sc-market-coin-icon" src="{{asset "imagesAndIcons/ethereum.svg"}}" alt="Ethereum" loading="lazy" width="48" height="48" data-market-icon>
                    <div class="sc-market-coin-info">
                        <span class="sc-market-coin-name" data-market-name>Ethereum</span>
                        <span class="sc-market-coin-symbol" data-market-symbol>ETH</span>
                    </div>
                    <div class="sc-market-coin-price">
                        <span class="sc-market-coin-price-value" data-market-price>$3,176.43</span>
                        <span class="sc-market-coin-change sc-md-change-up" data-market-change>↑1.35%</span>
                    </div>
                </a>
                <a class="sc-market-item" href="https://www.coingecko.com/en/coins/cardano" aria-label="Cardano" data-market-row="cardano" target="_blank" rel="noopener">
                    <img class="sc-market-coin-icon" src="{{asset "imagesAndIcons/cmp.svg"}}" alt="Cardano" loading="lazy" width="48" height="48" data-market-icon>
                    <div class="sc-market-coin-info">
                        <span class="sc-market-coin-name" data-market-name>Cardano</span>
                        <span class="sc-market-coin-symbol" data-market-symbol>ADA</span>
                    </div>
                    <div class="sc-market-coin-price">
                        <span class="sc-market-coin-price-value" data-market-price>$0.3992</span>
                        <span class="sc-market-coin-change sc-md-change-down" data-market-change>↓0.50%</span>
                    </div>
                </a>

            </div>
        </div>

        {{!-- Sponsored Content --}}
        {{#get "posts" filter="(tag:sponsored-content,tag:sponsored,tag:press-release)+tag:-jobs+tag:-job+tag:-careers+tag:-hiring+tag:-events+tag:-event+tag:-hash-jobs+tag:-hash-job+tag:-hash-careers+tag:-hash-hiring" limit="1" include="tags" order="published_at desc"}}
            {{#if posts}}
                {{#foreach posts}}
                <a class="sc-sponsored-card" href="{{url}}" aria-label="{{title}}">
                    <img src="{{#if feature_image}}{{img_url feature_image size="l"}}{{else}}{{asset "imagesAndIcons/yuan.png"}}{{/if}}" alt="{{title}}" loading="lazy">
                    <div class="sc-sponsored-card-overlay">
                        <div class="sc-sponsored-label">{{t "Sponsored Content"}}</div>
                        <div class="sc-sponsored-title">{{title}}</div>
                    </div>
                </a>
                {{/foreach}}
            {{else}}
                {{#get "posts" filter="featured:false+tag:-news+tag:-trending+tag:-markets+tag:-jobs+tag:-job+tag:-careers+tag:-hiring+tag:-events+tag:-event+tag:-hero-center+tag:-elon-center+tag:-elon-musk+tag:-hash-jobs+tag:-hash-job+tag:-hash-careers+tag:-hash-hiring" limit="1" order="published_at desc"}}
                    {{#foreach posts}}
                    <a class="sc-sponsored-card" href="{{url}}" aria-label="{{title}}">
                        <img src="{{#if feature_image}}{{img_url feature_image size="l"}}{{else}}{{asset "imagesAndIcons/yuan.png"}}{{/if}}" alt="{{title}}" loading="lazy">
                        <div class="sc-sponsored-card-overlay">
                            <div class="sc-sponsored-label">{{t "Sponsored Content"}}</div>
                            <div class="sc-sponsored-title">{{title}}</div>
                        </div>
                    </a>
                    {{/foreach}}
                {{/get}}
            {{/if}}
        {{/get}}
    </div>

    {{#get "posts" filter="(tag:hero-center,tag:elon-center,tag:elon-musk)+tag:-jobs+tag:-job+tag:-careers+tag:-hiring+tag:-events+tag:-event+tag:-sponsored-content+tag:-hash-jobs+tag:-hash-job+tag:-hash-careers+tag:-hash-hiring" limit="1" include="tags,authors" order="published_at desc"}}
        {{#if posts}}
            {{#foreach posts}}
            {{!-- Center Column: Featured Article --}}
            <div class="sc-content-grid-center">
                <article class="sc-featured-article">
                    <img class="sc-featured-article-img" src="{{#if feature_image}}{{img_url feature_image size="l"}}{{else}}{{asset "imagesAndIcons/elon.png"}}{{/if}}" alt="{{title}}" loading="lazy">
                    <div class="sc-featured-article-content">
                        <h2 class="sc-featured-article-title">
                            <a href="{{url}}">{{title}}</a>
                        </h2>
                        <p class="sc-featured-article-excerpt">{{#if custom_excerpt}}{{custom_excerpt}}{{else}}{{excerpt words="42"}}{{/if}}</p>
                        <div class="sc-featured-article-bottom">
                            <div class="sc-featured-article-meta">
                                {{#if primary_author.profile_image}}
                                <img class="sc-featured-article-author-img" src="{{img_url primary_author.profile_image size="xs"}}" alt="{{primary_author.name}}" loading="lazy">
                                {{/if}}
                                <span class="sc-featured-article-author-name">{{primary_author.name}}</span>
                                <span class="sc-featured-article-date">{{date published_at format="DD MMM YYYY"}}</span>
                            </div>
                            <div class="sc-featured-article-tags">
                                {{#foreach tags limit="3"}}
                                <a class="sc-featured-article-tag" href="{{url}}">{{name}}</a>
                                {{/foreach}}
                            </div>
                        </div>
                    </div>
                </article>
            </div>

            {{!-- Right Column: Featured Posts (excluding center hero post) --}}
            <div class="sc-content-grid-right">
                <div class="sc-featured-posts-card">
                    <div class="sc-featured-posts-header">
                        <span>{{t "Featured Posts"}}</span>
                        <a href="{{@site.url}}/tag/featured/" aria-label="{{t "View all featured posts"}}">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 14 14" fill="none">
                                <path d="M7.11588 2.91699L11.1992 7.00033L7.11588 11.0837" stroke="#F18F20" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                                <path d="M3.03255 7L11.1992 7" stroke="#F18F20" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </a>
                    </div>
                    {{#get "posts" filter="featured:true+id:-{{id}}+tag:-jobs+tag:-job+tag:-careers+tag:-hiring+tag:-events+tag:-event+tag:-sponsored-content+tag:-hero-center+tag:-elon-center+tag:-elon-musk+tag:-hash-jobs+tag:-hash-job+tag:-hash-careers+tag:-hash-hiring" limit="5" include="tags" order="published_at desc"}}
                        {{#if posts}}
                            {{#foreach posts}}
                                {{#if @first}}
                                <div class="sc-fp-main">
                                    <img class="sc-fp-main-img" src="{{#if feature_image}}{{img_url feature_image size="m"}}{{else}}{{asset "imagesAndIcons/metamask.png"}}{{/if}}" alt="{{title}}" loading="lazy">
                                    <div class="sc-fp-main-overlay">
                                        {{#if primary_tag}}
                                        <div class="sc-fp-main-category">{{t "Featured"}}</div>
                                        {{/if}}
                                        <div class="sc-fp-main-title"><a href="{{url}}">{{title}}</a></div>
                                    </div>
                                </div>
                                {{else}}
                                {{#if @second}}
                                <div class="sc-fp-list">
                                {{/if}}
                                    <div class="sc-fp-item">
                                        <span class="sc-fp-item-num">{{@number}}.</span>
                                        <div class="sc-fp-item-content">
                                            {{#if primary_tag}}
                                            <div class="sc-fp-item-category">{{primary_tag.name}}</div>
                                            {{/if}}
                                            <div class="sc-fp-item-title"><a href="{{url}}">{{title}}</a></div>
                                        </div>
                                    </div>
                                {{#if @last}}
                                </div>
                                {{/if}}
                                {{/if}}
                            {{/foreach}}
                        {{else}}
                            {{#get "posts" filter="featured:true+id:-{{id}}+tag:-jobs+tag:-job+tag:-careers+tag:-hiring+tag:-events+tag:-event+tag:-sponsored-content+tag:-hero-center+tag:-elon-center+tag:-elon-musk+tag:-hash-jobs+tag:-hash-job+tag:-hash-careers+tag:-hash-hiring" limit="5" include="tags" order="published_at desc"}}
                                {{#foreach posts}}
                                    {{#if @first}}
                                    <div class="sc-fp-main">
                                        <img class="sc-fp-main-img" src="{{#if feature_image}}{{img_url feature_image size="m"}}{{else}}{{asset "imagesAndIcons/metamask.png"}}{{/if}}" alt="{{title}}" loading="lazy">
                                        <div class="sc-fp-main-overlay">
                                            {{#if primary_tag}}
                                            <div class="sc-fp-main-category">{{t "Featured"}}</div>
                                            {{/if}}
                                            <div class="sc-fp-main-title"><a href="{{url}}">{{title}}</a></div>
                                        </div>
                                    </div>
                                    {{else}}
                                    {{#if @second}}
                                    <div class="sc-fp-list">
                                    {{/if}}
                                        <div class="sc-fp-item">
                                            <span class="sc-fp-item-num">{{@number}}.</span>
                                            <div class="sc-fp-item-content">
                                                {{#if primary_tag}}
                                                <div class="sc-fp-item-category">{{primary_tag.name}}</div>
                                                {{/if}}
                                                <div class="sc-fp-item-title"><a href="{{url}}">{{title}}</a></div>
                                            </div>
                                        </div>
                                    {{#if @last}}
                                    </div>
                                    {{/if}}
                                    {{/if}}
                                {{/foreach}}
                            {{/get}}
                        {{/if}}
                    {{/get}}
                </div>
            </div>
            {{/foreach}}
        {{else}}
            <div class="sc-content-grid-center">
                {{#get "posts" filter="tag:elon-musk+tag:-jobs+tag:-job+tag:-careers+tag:-hiring+tag:-events+tag:-event+tag:-sponsored-content+tag:-hash-jobs+tag:-hash-job+tag:-hash-careers+tag:-hash-hiring" limit="1" include="tags,authors" order="published_at desc"}}
                    {{#if posts}}
                        {{#foreach posts}}
                        <article class="sc-featured-article">
                            <img class="sc-featured-article-img" src="{{#if feature_image}}{{img_url feature_image size="l"}}{{else}}{{asset "imagesAndIcons/elon.png"}}{{/if}}" alt="{{title}}" loading="lazy">
                            <div class="sc-featured-article-content">
                                <h2 class="sc-featured-article-title">
                                    <a href="{{url}}">{{title}}</a>
                                </h2>
                                <p class="sc-featured-article-excerpt">{{#if custom_excerpt}}{{custom_excerpt}}{{else}}{{excerpt words="42"}}{{/if}}</p>
                                <div class="sc-featured-article-bottom">
                                    <div class="sc-featured-article-meta">
                                        {{#if primary_author.profile_image}}
                                        <img class="sc-featured-article-author-img" src="{{img_url primary_author.profile_image size="xs"}}" alt="{{primary_author.name}}" loading="lazy">
                                        {{/if}}
                                        <span class="sc-featured-article-author-name">{{primary_author.name}}</span>
                                        <span class="sc-featured-article-date">{{date published_at format="DD MMM YYYY"}}</span>
                                    </div>
                                    <div class="sc-featured-article-tags">
                                        {{#foreach tags limit="3"}}
                                        <a class="sc-featured-article-tag" href="{{url}}">{{name}}</a>
                                        {{/foreach}}
                                    </div>
                                </div>
                            </div>
                        </article>
                        {{/foreach}}
                    {{else}}
                        {{#get "posts" filter="featured:true+tag:-jobs+tag:-job+tag:-careers+tag:-hiring+tag:-events+tag:-event+tag:-sponsored-content+tag:-hero-center+tag:-elon-center+tag:-elon-musk+tag:-hash-jobs+tag:-hash-job+tag:-hash-careers+tag:-hash-hiring" limit="1" include="tags,authors" order="published_at desc"}}
                            {{#foreach posts}}
                            <article class="sc-featured-article">
                                <img class="sc-featured-article-img" src="{{#if feature_image}}{{img_url feature_image size="l"}}{{else}}{{asset "imagesAndIcons/elon.png"}}{{/if}}" alt="{{title}}" loading="lazy">
                                <div class="sc-featured-article-content">
                                    <h2 class="sc-featured-article-title">
                                        <a href="{{url}}">{{title}}</a>
                                    </h2>
                                    <p class="sc-featured-article-excerpt">{{#if custom_excerpt}}{{custom_excerpt}}{{else}}{{excerpt words="42"}}{{/if}}</p>
                                    <div class="sc-featured-article-bottom">
                                        <div class="sc-featured-article-meta">
                                            {{#if primary_author.profile_image}}
                                            <img class="sc-featured-article-author-img" src="{{img_url primary_author.profile_image size="xs"}}" alt="{{primary_author.name}}" loading="lazy">
                                            {{/if}}
                                            <span class="sc-featured-article-author-name">{{primary_author.name}}</span>
                                            <span class="sc-featured-article-date">{{date published_at format="DD MMM YYYY"}}</span>
                                        </div>
                                        <div class="sc-featured-article-tags">
                                            {{#foreach tags limit="3"}}
                                            <a class="sc-featured-article-tag" href="{{url}}">{{name}}</a>
                                            {{/foreach}}
                                        </div>
                                    </div>
                                </div>
                            </article>
                            {{/foreach}}
                        {{/get}}
                    {{/if}}
                {{/get}}
            </div>
            <div class="sc-content-grid-right">
                <div class="sc-featured-posts-card">
                    <div class="sc-featured-posts-header">
                        <span>{{t "Featured Posts"}}</span>
                        <a href="{{@site.url}}/tag/featured/" aria-label="{{t "View all featured posts"}}">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 14 14" fill="none">
                                <path d="M7.11588 2.91699L11.1992 7.00033L7.11588 11.0837" stroke="#F18F20" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                                <path d="M3.03255 7L11.1992 7" stroke="#F18F20" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </a>
                    </div>
                    {{#get "posts" filter="featured:true+tag:-jobs+tag:-job+tag:-careers+tag:-hiring+tag:-events+tag:-event+tag:-sponsored-content+tag:-hero-center+tag:-elon-center+tag:-elon-musk+tag:-hash-jobs+tag:-hash-job+tag:-hash-careers+tag:-hash-hiring" limit="5" include="tags" order="published_at desc"}}
                        {{#foreach posts}}
                            {{#if @first}}
                            <div class="sc-fp-main">
                                <img class="sc-fp-main-img" src="{{#if feature_image}}{{img_url feature_image size="m"}}{{else}}{{asset "imagesAndIcons/metamask.png"}}{{/if}}" alt="{{title}}" loading="lazy">
                                <div class="sc-fp-main-overlay">
                                    {{#if primary_tag}}
                                    <div class="sc-fp-main-category">{{t "Featured"}}</div>
                                    {{/if}}
                                    <div class="sc-fp-main-title"><a href="{{url}}">{{title}}</a></div>
                                </div>
                            </div>
                            {{else}}
                            {{#if @second}}
                            <div class="sc-fp-list">
                            {{/if}}
                                <div class="sc-fp-item">
                                    <span class="sc-fp-item-num">{{@number}}.</span>
                                    <div class="sc-fp-item-content">
                                        {{#if primary_tag}}
                                        <div class="sc-fp-item-category">{{primary_tag.name}}</div>
                                        {{/if}}
                                        <div class="sc-fp-item-title"><a href="{{url}}">{{title}}</a></div>
                                    </div>
                                </div>
                            {{#if @last}}
                            </div>
                            {{/if}}
                            {{/if}}
                        {{/foreach}}
                    {{/get}}
                </div>
            </div>
        {{/if}}
    {{/get}}

</section>
