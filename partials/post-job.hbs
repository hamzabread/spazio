<div class="sc-job-post-page">
    <div class="sc-job-post-breadcrumbs">
        <nav class="sc-job-post-bc gh-container" aria-label="{{t "Breadcrumb"}}">
            <a class="sc-job-post-bc-link" href="{{@site.url}}/jobs/">{{t "Jobs"}}</a>
            <span class="sc-job-post-bc-sep" aria-hidden="true">›</span>
            <span class="sc-job-post-bc-current">{{title}}</span>
        </nav>
    </div>

    <main class="main flex-1 sc-job-post-main">
        <div class="gh-container sc-job-post-layout">
            <article class="sc-job-post-primary" aria-labelledby="sc-job-post-title">
                <div class="sc-job-post-card">
                    <div class="sc-job-post-card-top">
                        <div class="sc-job-post-card-head">
                            <div class="sc-job-post-card-brand">
                                {{#if feature_image}}
                                <img class="sc-job-post-logo" src="{{img_url feature_image size="s"}}" alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{#primary_author}}{{name}}{{/primary_author}}{{/if}}" width="64" height="64" loading="eager" decoding="async">
                                {{else}}
                                <div class="sc-job-post-logo sc-job-post-logo--placeholder" aria-hidden="true"></div>
                                {{/if}}
                                <div class="sc-job-post-card-titles">
                                    <h1 id="sc-job-post-title" class="sc-job-post-title">{{title}}</h1>
                                    {{#primary_author}}
                                    <p class="sc-job-post-company">{{name}}</p>
                                    {{/primary_author}}
                                </div>
                            </div>
                            <button type="button" class="sc-job-post-card-share" data-job-share aria-label="{{t "SHARE"}}">
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                                    <path d="M15 6.66699C16.3807 6.66699 17.5 5.5477 17.5 4.16699C17.5 2.78628 16.3807 1.66699 15 1.66699C13.6193 1.66699 12.5 2.78628 12.5 4.16699C12.5 5.5477 13.6193 6.66699 15 6.66699Z" stroke="#EBEFF2" stroke-width="1.66667" stroke-linecap="round" stroke-linejoin="round"/>
                                    <path d="M5 12.5C6.38071 12.5 7.5 11.3807 7.5 10C7.5 8.61929 6.38071 7.5 5 7.5C3.61929 7.5 2.5 8.61929 2.5 10C2.5 11.3807 3.61929 12.5 5 12.5Z" stroke="#EBEFF2" stroke-width="1.66667" stroke-linecap="round" stroke-linejoin="round"/>
                                    <path d="M15 18.333C16.3807 18.333 17.5 17.2137 17.5 15.833C17.5 14.4523 16.3807 13.333 15 13.333C13.6193 13.333 12.5 14.4523 12.5 15.833C12.5 17.2137 13.6193 18.333 15 18.333Z" stroke="#EBEFF2" stroke-width="1.66667" stroke-linecap="round" stroke-linejoin="round"/>
                                    <path d="M7.1582 11.2588L12.8499 14.5755" stroke="#EBEFF2" stroke-width="1.66667" stroke-linecap="round" stroke-linejoin="round"/>
                                    <path d="M12.8415 5.425L7.1582 8.74167" stroke="#EBEFF2" stroke-width="1.66667" stroke-linecap="round" stroke-linejoin="round"/>
                                </svg>
                            </button>
                        </div>

                        <div class="sc-job-post-meta-row">
                            <span class="sc-job-post-meta-item sc-job-post-meta-item--icon-end">
                                <span class="sc-job-post-meta-text">{{#has tag="#remote"}}{{t "Remote"}}{{else}}{{#has tag="#hybrid"}}{{t "Hybrid"}}{{else}}{{#has tag="#onsite"}}{{t "On-site"}}{{else}}{{#has tag="#on-site"}}{{t "On-site"}}{{else}}{{t "Remote"}}{{/has}}{{/has}}{{/has}}{{/has}}</span>
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                                    <path d="M7.00018 7.83412C8.00533 7.83412 8.82018 7.01928 8.82018 6.01412C8.82018 5.00896 8.00533 4.19412 7.00018 4.19412C5.99502 4.19412 5.18018 5.00896 5.18018 6.01412C5.18018 7.01928 5.99502 7.83412 7.00018 7.83412Z" stroke="#F18F20" stroke-width="0.875"/>
                                    <path d="M2.11182 4.95249C3.26099 -0.0991754 10.7452 -0.093342 11.8885 4.95832C12.5593 7.92166 10.716 10.43 9.10016 11.9817C7.92766 13.1133 6.07266 13.1133 4.89432 11.9817C3.28432 10.43 1.44099 7.91582 2.11182 4.95249Z" stroke="#F18F20" stroke-width="0.875"/>
                                </svg>
                            </span>
                            <span class="sc-job-post-meta-item sc-job-post-meta-item--icon-end">
                                <span class="sc-job-post-meta-text">{{#has tag="#full-time"}}{{t "Full-time"}}{{else}}{{#has tag="#part-time"}}{{t "Part-time"}}{{else}}{{#has tag="#contract"}}{{t "Contract"}}{{else}}{{#has tag="#internship"}}{{t "Internship"}}{{else}}{{#has tag="#freelance"}}{{t "Freelance"}}{{else}}{{t "Full-time"}}{{/has}}{{/has}}{{/has}}{{/has}}{{/has}}</span>
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                                    <path d="M4.90001 3.79166H9.10002C11.0834 3.79166 11.2817 4.71916 11.4159 5.85082L11.9409 10.2258C12.11 11.6608 11.6667 12.8333 9.62502 12.8333H4.38085C2.33335 12.8333 1.89001 11.6608 2.06501 10.2258L2.59002 5.85082C2.71835 4.71916 2.91668 3.79166 4.90001 3.79166Z" stroke="#F18F20" stroke-width="0.875" stroke-linecap="round" stroke-linejoin="round"/>
                                    <path d="M4.6665 4.66666V2.62499C4.6665 1.74999 5.24984 1.16666 6.12484 1.16666H7.87484C8.74984 1.16666 9.33317 1.74999 9.33317 2.62499V4.66666" stroke="#F18F20" stroke-width="0.875" stroke-linecap="round" stroke-linejoin="round"/>
                                    <path d="M11.9057 9.93417H4.6665" stroke="#F18F20" stroke-width="0.875" stroke-linecap="round" stroke-linejoin="round"/>
                                </svg>
                            </span>
                            <span class="sc-job-post-meta-item sc-job-post-meta-salary">
                                {{#has tag="#salary-40k-60k"}}$40K - $60K{{else}}{{#has tag="#salary-60k-90k"}}$60K - $90K{{else}}{{#has tag="#salary-90k-120k"}}$90K - $120K{{else}}{{#has tag="#salary-90k-180k"}}$90K - $180K{{else}}{{#has tag="#salary-120k-plus"}}$120K+{{else}}{{#has tag="#salary-negotiable"}}{{t "Salary negotiable"}}{{else}}{{t "Salary negotiable"}}{{/has}}{{/has}}{{/has}}{{/has}}{{/has}}{{/has}}
                            </span>
                            <span class="sc-job-post-meta-item sc-job-post-meta-item--time">
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                                    <circle cx="12" cy="12" r="10" stroke="#F18F20" stroke-width="2"/>
                                    <polyline points="12 6 12 12 16 14" stroke="#F18F20" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                </svg>
                                <span class="sc-job-post-meta-text">{{date published_at timeago="true"}}</span>
                            </span>
                        </div>
                    </div>

                    <div class="sc-job-post-card-body">
                        <div class="sc-job-post-body gh-content">
                            {{{content}}}
                        </div>
                    </div>
                </div>
            </article>

            <aside class="sc-job-post-sidebar" aria-label="{{t "Job sidebar"}}">
                <section class="sc-job-post-actions sc-job-sidebar-card">
                    <a class="sc-job-post-apply-btn" href="mailto:jobs@spaziocrypto.com?subject=Job%20application%3A%20{{slug}}&body={{url absolute='true'}}" target="_blank" rel="noopener">{{t "Apply Now"}}</a>
                    <button type="button" class="sc-job-post-save-btn" data-job-save data-job-id="{{id}}" aria-pressed="false">{{t "Save Job"}}</button>
                </section>

                <section class="sc-job-sidebar-card sc-job-info-card">
                    <h2 class="sc-job-sidebar-heading">{{t "Job Information"}}</h2>
                    <dl class="sc-job-info-list">
                        <div class="sc-job-info-row">
                            <dt>{{t "Category"}}</dt>
                            <dd id="sc-job-info-category-dd" data-job-category-dd>
                                {{#foreach tags visibility="all"}}
                                <template class="sc-job-category-tag" data-slug="{{slug}}">{{name}}</template>
                                {{/foreach}}
                            </dd>
                        </div>
                        <div class="sc-job-info-row">
                            <dt>{{t "Employment Type"}}</dt>
                            <dd data-job-body-meta="employment">{{#has tag="#full-time"}}{{t "Full-time"}}{{else}}{{#has tag="#part-time"}}{{t "Part-time"}}{{else}}{{#has tag="#contract"}}{{t "Contract"}}{{else}}{{#has tag="#internship"}}{{t "Internship"}}{{else}}{{#has tag="#freelance"}}{{t "Freelance"}}{{else}}{{t "Full-time"}}{{/has}}{{/has}}{{/has}}{{/has}}{{/has}}</dd>
                        </div>
                        <div class="sc-job-info-row">
                            <dt>{{t "Location"}}</dt>
                            <dd data-job-body-meta="location">{{#has tag="#remote"}}{{t "Remote"}}{{else}}{{#has tag="#hybrid"}}{{t "Hybrid"}}{{else}}{{#has tag="#onsite"}}{{t "On-site"}}{{else}}{{#has tag="#on-site"}}{{t "On-site"}}{{else}}{{t "Remote"}}{{/has}}{{/has}}{{/has}}{{/has}}</dd>
                        </div>
                        <div class="sc-job-info-row">
                            <dt>{{t "Salary Range"}}</dt>
                            <dd data-job-body-meta="salary">{{#has tag="#salary-40k-60k"}}$40K - $60K{{else}}{{#has tag="#salary-60k-90k"}}$60K - $90K{{else}}{{#has tag="#salary-90k-120k"}}$90K - $120K{{else}}{{#has tag="#salary-90k-180k"}}$90K - $180K{{else}}{{#has tag="#salary-120k-plus"}}$120K+{{else}}{{#has tag="#salary-negotiable"}}{{t "Salary negotiable"}}{{else}}—{{/has}}{{/has}}{{/has}}{{/has}}{{/has}}{{/has}}</dd>
                        </div>
                    </dl>
                </section>

                <section class="sc-job-sidebar-card">
                    <h2 class="sc-job-sidebar-heading">{{t "TAGS"}}</h2>
                    <div class="sc-job-post-tag-row sc-job-post-tag-row--sidebar">
                        {{#foreach tags visibility="public"}}
                            {{#match slug "jobs"}}
                            {{else}}
                                {{#match slug "careers"}}
                                {{else}}
                                    {{#match slug "job"}}
                                    {{else}}
                                        {{#match slug "hiring"}}
                                        {{else}}
                                            <span class="sc-job-post-tag sc-job-post-tag--pill">{{name}}</span>
                                        {{/match}}
                                    {{/match}}
                                {{/match}}
                            {{/match}}
                        {{/foreach}}
                    </div>
                </section>
            </aside>
        </div>
    </main>
</div>
