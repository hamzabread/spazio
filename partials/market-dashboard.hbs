<section class="sc-market-dashboard" data-market-dashboard="coingecko">
    <div class="sc-market-dashboard-inner">
        <div class="sc-market-dashboard-header">
            <h2 class="sc-market-dashboard-title">{{t "Crypto Market"}}</h2>
            {{#if @custom.market_source_tag}}
            <a class="sc-market-dashboard-viewall" href="{{@site.url}}/tag/{{@custom.market_source_tag}}/">
                {{t "View full market"}} →
            </a>
            {{else}}
            <a class="sc-market-dashboard-viewall" href="{{@site.url}}/tag/markets/">
                {{t "View full market"}} →
            </a>
            {{/if}}
        </div>
        <div class="sc-market-dashboard-grid">
            {{!-- Market Sentiment Gauge --}}
            <div class="sc-md-card sc-md-sentiment" data-md-sentiment-card>
                <div class="sc-md-card-label">{{t "Market Sentiment"}}</div>
                <img class="sc-md-sentiment-svg" src="{{asset "imagesAndIcons/market-sentiment.svg"}}" alt="{{t "Market Sentiment Gauge"}}" loading="lazy" width="290" height="174">
                <div class="sc-md-card-meta" data-md-sentiment-meta>
                    {{#if @custom.market_overview_source_filter}}
                    {{#get "posts" filter=@custom.market_overview_source_filter limit="1" include="tags" order="published_at desc"}}
                        {{#if posts}}
                            {{#foreach posts}}
                            <a href="{{url}}">{{title}}</a>
                            {{/foreach}}
                        {{else}}
                            {{#get "posts" limit="1" include="tags" order="published_at desc"}}
                                {{#foreach posts}}
                                <a href="{{url}}">{{title}}</a>
                                {{/foreach}}
                            {{/get}}
                        {{/if}}
                    {{/get}}
                    {{else}}
                    {{#get "posts" filter="tags:[markets,market]" limit="1" include="tags" order="published_at desc"}}
                        {{#if posts}}
                            {{#foreach posts}}
                            <a href="{{url}}">{{title}}</a>
                            {{/foreach}}
                        {{else}}
                            {{#get "posts" limit="1" include="tags" order="published_at desc"}}
                                {{#foreach posts}}
                                <a href="{{url}}">{{title}}</a>
                                {{/foreach}}
                            {{/get}}
                        {{/if}}
                    {{/get}}
                    {{/if}}
                </div>
            </div>

            {{!-- Crypto Market Cap --}}
            <div class="sc-md-card sc-md-cap" data-md-cap-card>
                <div class="sc-md-cap-top">
                    <div class="sc-md-card-title">{{t "Crypto Market Cap"}}</div>
                    <div class="sc-md-cap-value sc-total-mcap" data-md-total-mcap>$2.79T</div>
                    <div class="sc-md-cap-change">
                        <svg class="sc-md-cap-arrow" data-md-cap-arrow width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="18 15 12 9 6 15"/></svg>
                        <span class="sc-md-cap-pct sc-mcap-change sc-md-cap-change-up" data-md-mcap-change>+0.79%</span>
                    </div>
                </div>
                <div class="sc-md-chart-placeholder">
                    <svg xmlns="http://www.w3.org/2000/svg" width="288" height="35" viewBox="0 0 288 35" fill="none" class="sc-md-mini-chart" data-md-mini-chart>
                        <path data-md-mini-chart-area fill-rule="evenodd" clip-rule="evenodd" d="M0 34.3182L0 14.995C0 14.995 16.0053 23.809 18.7609 23.5447C33.6309 22.1184 51.359 13.3306 59.67 13.3306C67.981 13.3306 94.8466 20.6436 106.659 20.6436C118.471 20.6436 141.054 0 150.087 0C159.12 0 176.269 14.995 184.619 14.995C192.969 14.995 218.877 9.07461 227.215 9.07461C235.553 9.07461 257.093 13.3306 265.432 13.3306C268.428 13.3306 287.667 10.5043 287.667 10.5043V34.3182H0Z" fill="url(#mdMiniChartGradientUp)"/>
                        <defs>
                            <linearGradient id="mdMiniChartGradientUp" x1="2.89569" y1="-16.7515" x2="2.89569" y2="39.3346" gradientUnits="userSpaceOnUse">
                                <stop stop-color="#F9992A"/>
                                <stop offset="1" stop-color="#F9992A" stop-opacity="0.01"/>
                            </linearGradient>
                            <linearGradient id="mdMiniChartGradientDown" x1="2.89569" y1="-16.7515" x2="2.89569" y2="39.3346" gradientUnits="userSpaceOnUse">
                                <stop stop-color="#EF4444"/>
                                <stop offset="1" stop-color="#EF4444" stop-opacity="0.01"/>
                            </linearGradient>
                        </defs>
                    </svg>
                </div>
            </div>

            {{!-- Top Gainers --}}
            <div class="sc-md-card sc-md-table-card">
                <div class="sc-md-card-title">{{t "Top Gainers"}}</div>
                <div class="sc-md-table sc-md-gainers-table" data-md-gainers-table>
                    <div class="sc-md-table-header">
                        <span>{{t "Trading Pairs"}}</span>
                        <span>{{t "Last Traded Price"}}</span>
                        <span>{{t "24H Change"}}</span>
                    </div>
                    <div class="sc-md-table-row" data-md-gainers-row>
                        <div class="sc-md-pair">
                            <img src="{{asset "imagesAndIcons/bitcoin.svg"}}" alt="Bitcoin" class="sc-md-pair-icon">
                            <div class="sc-md-pair-text">
                                <span class="sc-md-pair-name">Bitcoin</span>
                                <span class="sc-md-pair-symbol">BTC</span>
                            </div>
                        </div>
                        <span class="sc-md-price">$93,041.34</span>
                        <span class="sc-md-table-change-up">+2.04%</span>
                    </div>
                    <div class="sc-md-table-row" data-md-gainers-row>
                        <div class="sc-md-pair">
                            <img src="{{asset "imagesAndIcons/ethereum.svg"}}" alt="Ethereum" class="sc-md-pair-icon">
                            <div class="sc-md-pair-text">
                                <span class="sc-md-pair-name">Ethereum</span>
                                <span class="sc-md-pair-symbol">ETH</span>
                            </div>
                        </div>
                        <span class="sc-md-price">$3,176.43</span>
                        <span class="sc-md-table-change-up">+1.35%</span>
                    </div>
                    <div class="sc-md-table-row" data-md-gainers-row>
                        <div class="sc-md-pair">
                            <img src="{{asset "imagesAndIcons/cmp.svg"}}" alt="Cardano" class="sc-md-pair-icon">
                            <div class="sc-md-pair-text">
                                <span class="sc-md-pair-name">Cardano</span>
                                <span class="sc-md-pair-symbol">ADA</span>
                            </div>
                        </div>
                        <span class="sc-md-price">$0.3992</span>
                        <span class="sc-md-table-change-down">-0.50%</span>
                    </div>
                </div>
            </div>

            {{!-- Trending --}}
            <div class="sc-md-card sc-md-table-card">
                <div class="sc-md-card-title">{{t "Trending"}}</div>
                <div class="sc-md-table sc-md-trending-table" data-md-trending-table>
                    <div class="sc-md-table-header">
                        <span>{{t "Trading Pairs"}}</span>
                        <span>{{t "Last Traded Price"}}</span>
                        <span>{{t "24H Change"}}</span>
                    </div>
                    <div class="sc-md-table-row" data-md-trending-row>
                        <div class="sc-md-pair">
                            <img src="{{asset "imagesAndIcons/hon.svg"}}" alt="Hon" class="sc-md-pair-icon">
                            <div class="sc-md-pair-text">
                                <span class="sc-md-pair-name">HON</span>
                                <span class="sc-md-pair-symbol">HON/USDT</span>
                            </div>
                        </div>
                        <span class="sc-md-price">$0.000230</span>
                        <span class="sc-md-table-change-up">+12.08%</span>
                    </div>
                    <div class="sc-md-table-row" data-md-trending-row>
                        <div class="sc-md-pair">
                            <img src="{{asset "imagesAndIcons/cmp.svg"}}" alt="CMP" class="sc-md-pair-icon">
                            <div class="sc-md-pair-text">
                                <span class="sc-md-pair-name">CMP</span>
                                <span class="sc-md-pair-symbol">CMP/USDT</span>
                            </div>
                        </div>
                        <span class="sc-md-price">$0.00206</span>
                        <span class="sc-md-table-change-down">-6.21%</span>
                    </div>
                    <div class="sc-md-table-row" data-md-trending-row>
                        <div class="sc-md-pair">
                            <img src="{{asset "imagesAndIcons/shark.svg"}}" alt="Shark" class="sc-md-pair-icon">
                            <div class="sc-md-pair-text">
                                <span class="sc-md-pair-name">SHARK</span>
                                <span class="sc-md-pair-symbol">SHARK/USDT</span>
                            </div>
                        </div>
                        <span class="sc-md-price">$0.0482</span>
                        <span class="sc-md-table-change-up">+21.54%</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
