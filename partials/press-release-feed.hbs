<section class="press-release-feed-container">
    <div class="gh-container">
         
            {{#get "posts" filter="tags:[press-release,comunicato-stampa,communique-de-presse,comunicado-de-prensa,pressemitteilung,priess-rieliz,bodo-jaryo,puresuririsu,xin-wen-gao]" include="tags,authors" order="published_at desc"}}
                {{#if posts}}
                <div class="gh-sidebar-featured-posts-wrapper">
                    <h3 class="gh-sidebar-featured-posts-title">{{t "Sponsored Press Releases"}}</h3>
                    <div class="gh-small-slider-container">
                        <div class="gh-sponsored-slider swiper">
                            <div class="gh-small-slider-wrapper swiper-wrapper">
                                {{#foreach posts from="1" to="6"}}
                                        <div class="gh-sidebar-feat-post{{#has tag="#video"}} tag-video{{/has}} {{post_class}}{{#is "post"}} gh-read-next-card{{/is}} swiper-slide">
                                            <div class="gh-sidebar-feat-post-img-video-wrapper">
                                                {{#if feature_image}}
                                                <a class="gh-sidebar-feat-post-image-wrapper-link" href="{{url}}" aria-label="{{title}} {{t "post link"}}">
                                                    <picture>
                                                        <source srcset="{{img_url feature_image size="300" format="webp" }} 300w, {{img_url feature_image size="200" format="webp" }} 200w" sizes="88px"
                                                            type="image/webp">
                                                        <img class="gh-sidebar-feat-post-image" srcset="{{img_url feature_image size="300"}} 300w, {{img_url feature_image size="200"}} 200w" sizes="88px"
                                                            src="{{img_url feature_image size="300"}}"
                                                            alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}} {{t "post image"}}{{/if}}"
                                                            loading="lazy">
                                                    </picture>
                                                </a>
                                                {{else}}
                                                <a class="gh-sidebar-feat-post-image-wrapper-link--noImage" href="{{url}}" aria-label="{{title}} {{t "post link"}}">
                                                    {{#if @site.icon}}
                                                    <picture>
                                                        <source srcset="{{img_url @site.icon size="100" format="webp" }} 100w" sizes="18px"
                                                            type="image/webp">
                                                        <img class="gh-sidebar-feat-post-image-wrapper-link--noImage__icon" srcset="{{img_url @site.icon size="100"}} 100w" sizes="18px"
                                                            src="{{img_url @site.icon size="100"}}"
                                                            alt="{{@site.title}} {{t "icon"}}">
                                                    </picture>
                                                    {{else}}
                                                    <h2 class="gh-sidebar-feat-post-image-wrapper-link--noImage__name">{{@site.title}}</h3>
                                                    {{/if}}
                                                </a>
                                                {{/if}}
                                                {{#has tag="#video"}}
                                                <div class="gh-sidebar-feat-post-video-wrapper">
                                                    {{content}}
                                                </div>
                                                <a class="gh-sidebar-feat-post-video-link" href="{{url}}" aria-label="{{title}} {{t "post link"}}"></a>
                                                {{/has}}
                                            </div>
                                            <div class="gh-sidebar-feat-post-content">
                                                <div class="gh-sidebar-feat-post-meta">
                                                    {{#if reading_time}}
                                                    <div class="gh-sidebar-feat-post-authors">
                                                        <span class="gh-sidebar-feat-post-author">
                                                        {{reading_time minute=(t "1 min read") minutes=(t "% min read")}}
                                                        </span>
                                                    </div>
                                                    {{/if}}
                                                    <span class="gh-sidebar-feat-post-date">
                                                        <time datetime="{{date format=" YYYY-MM-DD"}}">{{date format="MMM D, YYYY"}}</time>
                                                    </span>
                                                    
                                                    
                                                    
                                                </div>
                                                <h4 class="gh-sidebar-feat-post-title">
                                                    <a href="{{url}}">{{title}}</a>
                                                </h4>
                                                <span class="press-release-tag">{{t "Press Releases"}}</span>
                                            </div>
                                </div>
                                {{/foreach}}
                            </div>
                            <div class="gh-small-slider-pagination"></div>
                        </div>
                        <button class="gh-small-slider-button-prev gh-sponsored-slider-button-prev">
                            {{>icons/chevron-left}}
                        </button>
                        <button class="gh-small-slider-button-next gh-sponsored-slider-button-next">
                            {{>icons/chevron-right}}
                        </button>
                    </div>
                    
        {{!-- <a href="/web3-guide/" class="gh-small-slider-button-all gh-secondary-button" aria-label="All Press Releases →">
            {{t "All Press Releases"}} →
        </a> --}}
    </div>
    {{/if}}
    {{/get}}
        
    </div>
</section>

<script>
    //Document ready
    document.addEventListener("DOMContentLoaded", function () {
        //Init Swiper
        var swiper = new Swiper('.gh-sponsored-slider', {
            slidesPerView: 1,
            spaceBetween: 30,
            loop: true,
            navigation: {
                nextEl: '.gh-sponsored-slider-button-next',
                prevEl: '.gh-sponsored-slider-button-prev',
            },
            pagination: false,
            breakpoints: {
                768: {
                    slidesPerView: 2,
                    spaceBetween: 20,
                },
                992: {
                    slidesPerView: 3,
                    spaceBetween: 30,
                },
                1024: {
                    slidesPerView: 4,
                    spaceBetween: 30,
                },
            },
        });
    });
</script>