<div class="sc-crypto-prices-page">
    <section class="sc-contact-hero" aria-labelledby="sc-crypto-prices-hero-title">
        <div class="sc-contact-hero-inner gh-container">
            <span class="sc-contact-hero-chip">{{t "Crypto prices chip"}}</span>
            <h1 id="sc-crypto-prices-hero-title">{{t "Crypto prices title before"}} <span>{{t "Crypto prices title accent"}}</span></h1>
            <p>{{t "Crypto prices hero lede"}}</p>
        </div>
    </section>

    <section class="sc-jobs sc-crypto-prices-listing" aria-labelledby="sc-crypto-prices-board-title">
