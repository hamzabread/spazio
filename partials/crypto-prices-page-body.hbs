            <div class="sc-crypto-prices-content">
                <div class="sc-crypto-prices-table-wrap">
                    <table class="sc-crypto-prices-table">
                        <colgroup>
                            <col class="sc-crypto-prices-col-rank">
                            <col class="sc-crypto-prices-col-name">
                            <col span="7">
                        </colgroup>
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>{{t "Name"}}</th>
                                <th>Price</th>
                                <th>1H %</th>
                                <th>24H %</th>
                                <th>7D %</th>
                                <th>Volume (24H)</th>
                                <th>Market Cap</th>
                                <th>Price Graph (7D)</th>
                            </tr>
                        </thead>
