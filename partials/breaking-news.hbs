<section class="sc-breaking-news">
    <div class="sc-breaking-news-inner">
        <div class="sc-breaking-news-header">
            <div class="sc-breaking-news-title-group">
                <span class="sc-breaking-news-dot"></span>
                <h2 class="sc-breaking-news-title">{{t "Breaking News"}}</h2>
                <span class="sc-breaking-news-live">{{t "Live"}}</span>
            </div>
            <a class="sc-breaking-news-viewall" href="{{@site.url}}/tag/news/">
                {{t "View All"}} →
            </a>
        </div>
        <div class="sc-breaking-news-grid">
            {{!-- Row 1 --}}
            <div class="sc-bn-card">
                <img class="sc-bn-card-img" src="{{asset "imagesAndIcons/sec.svg"}}" alt="SEC" loading="lazy">
                <div class="sc-bn-card-content">
                    <span class="sc-bn-category sc-bn-cat-regulation">{{t "Regulation"}}</span>
                    <h3 class="sc-bn-card-title">{{t "SEC Approves Multiple Bitcoin ETFs, Opening Doors for Institutional Investment"}}</h3>
                    <div class="sc-bn-card-meta">
                        <svg class="sc-bn-clock" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                        <span>{{t "15 mins ago"}}</span>
                        <svg class="sc-bn-trending" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#22C55E" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
                    </div>
                </div>
            </div>
            <div class="sc-bn-card">
                <img class="sc-bn-card-img" src="{{asset "imagesAndIcons/ethereum.svg"}}" alt="Ethereum" loading="lazy">
                <div class="sc-bn-card-content">
                    <span class="sc-bn-category sc-bn-cat-technology">{{t "Technology"}}</span>
                    <h3 class="sc-bn-card-title">{{t "Ethereum Network Upgrade Successfully Implemented, Gas Fees Drop 40%"}}</h3>
                    <div class="sc-bn-card-meta">
                        <svg class="sc-bn-clock" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                        <span>{{t "1 hour ago"}}</span>
                        <svg class="sc-bn-trending" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#22C55E" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
                    </div>
                </div>
            </div>
            <div class="sc-bn-card">
                <img class="sc-bn-card-img" src="{{asset "imagesAndIcons/defi.svg"}}" alt="DeFi" loading="lazy">
                <div class="sc-bn-card-content">
                    <span class="sc-bn-category sc-bn-cat-defi">{{t "DeFi"}}</span>
                    <h3 class="sc-bn-card-title">{{t "Major DeFi Protocol Launches Layer 2 Solution for Faster Transactions"}}</h3>
                    <div class="sc-bn-card-meta">
                        <svg class="sc-bn-clock" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                        <span>{{t "2 hours ago"}}</span>
