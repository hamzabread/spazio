                    </div>
                </div>
            </div>
            {{!-- Row 2 --}}
            <div class="sc-bn-card">
                <img class="sc-bn-card-img" src="{{asset "imagesAndIcons/survery.svg"}}" alt="Business" loading="lazy">
                <div class="sc-bn-card-content">
                    <span class="sc-bn-category sc-bn-cat-business">{{t "Business"}}</span>
