                    </div>
                </div>
            </div>
            <div class="sc-bn-card">
                <img class="sc-bn-card-img" src="{{asset "imagesAndIcons/bitcoin.svg"}}" alt="Mining" loading="lazy">
                <div class="sc-bn-card-content">
                    <span class="sc-bn-category sc-bn-cat-mining">{{t "Mining"}}</span>
