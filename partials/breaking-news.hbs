<section class="sc-breaking-news">
    <div class="sc-breaking-news-inner">
        <div class="sc-breaking-news-header">
            <div class="sc-breaking-news-title-group">
                <span class="sc-breaking-news-dot"></span>
                <h2 class="sc-breaking-news-title">{{t "Breaking News"}}</h2>
                <span class="sc-breaking-news-live">{{t "Live"}}</span>
            </div>
            <a class="sc-breaking-news-viewall" href="{{@site.url}}/tag/news/">
                {{t "View All"}} →
            </a>
        </div>
        <div class="sc-breaking-news-grid">
            {{#get "posts" filter="tag:hash-breaking+tag:-jobs+tag:-job+tag:-careers+tag:-hiring+tag:-events+tag:-event+tag:-sponsored+tag:-sponsored-content+tag:-press-release+tag:-press-releases+tag:-hash-jobs+tag:-hash-job+tag:-hash-careers+tag:-hash-hiring+slug:-coming-soon" include="authors,tags" limit="6" order="published_at desc"}}
                {{#if posts}}
                    {{#foreach posts}}
                    <article class="sc-bn-card">
                        <a href="{{url}}" aria-label="{{title}}">
                            <img class="sc-bn-card-img" src="{{#if feature_image}}{{img_url feature_image size="s"}}{{else}}{{asset "imagesAndIcons/bitcoin.svg"}}{{/if}}" alt="{{title}}" loading="lazy">
                        </a>
                        <div class="sc-bn-card-content">
                            <span class="sc-bn-category sc-bn-internal-only">
                                {{#foreach tags visibility="all"}}
                                <span class="sc-bn-tag-candidate" data-slug="{{slug}}">{{name}}</span>
                                {{/foreach}}
                            </span>
                            <h3 class="sc-bn-card-title"><a href="{{url}}">{{title}}</a></h3>
                            <div class="sc-bn-card-meta">
                                <svg class="sc-bn-clock" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                                <span>{{date published_at timeago="true"}}</span>
                                <svg class="sc-bn-trending" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#22C55E" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
                            </div>
                        </div>
                    </article>
                    {{/foreach}}
                {{else}}
                    {{#get "posts" filter="tag:hash-breaking+tag:-jobs+tag:-job+tag:-careers+tag:-hiring+tag:-events+tag:-event+tag:-sponsored+tag:-sponsored-content+tag:-press-release+tag:-press-releases+tag:-hash-jobs+tag:-hash-job+tag:-hash-careers+tag:-hash-hiring+slug:-coming-soon" include="authors,tags" limit="6" order="published_at desc"}}
                        {{#foreach posts}}
                        <article class="sc-bn-card">
                            <a href="{{url}}" aria-label="{{title}}">
                                <img class="sc-bn-card-img" src="{{#if feature_image}}{{img_url feature_image size="s"}}{{else}}{{asset "imagesAndIcons/bitcoin.svg"}}{{/if}}" alt="{{title}}" loading="lazy">
                            </a>
                            <div class="sc-bn-card-content">
                                <span class="sc-bn-category sc-bn-internal-only">
                                    {{#foreach tags visibility="all"}}
                                    <span class="sc-bn-tag-candidate" data-slug="{{slug}}">{{name}}</span>
                                    {{/foreach}}
                                </span>
                                <h3 class="sc-bn-card-title"><a href="{{url}}">{{title}}</a></h3>
                                <div class="sc-bn-card-meta">
                                    <svg class="sc-bn-clock" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                                    <span>{{date published_at timeago="true"}}</span>
                                    <svg class="sc-bn-trending" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#22C55E" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
                                </div>
                            </div>
                        </article>
                        {{/foreach}}
                    {{/get}}
                {{/if}}
            {{/get}}
        </div>
    </div>
</section>
