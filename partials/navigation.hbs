{{#if isSecondary}}
<ul class="gh-secondary-nav">
    {{#foreach navigation}}
    <li class="gh-secondary-nav-item gh-secondary-nav-{{slug}}"><a class="gh-secondary-nav-link" href="{{url absolute=" true"}}">{{label}}</a></li>
    {{/foreach}}
</ul>
{{else}}
<ul class="gh-header-navigation">
    {{#foreach navigation}}
    <li class="gh-header-nav-item">
        <a class="gh-header-nav-link gh-navigation-{{slug}}{{#if current}} nav-current{{/if}}" href="{{url absolute="
            true"}}">
            {{label}}
        </a>
    </li>
    {{/foreach}}
    {{!-- <li class="gh-subnav-icon">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="https://www.w3.org/2000/svg">
            <path
                d="M10 5.375C10.8975 5.375 11.625 4.64746 11.625 3.75C11.625 2.85254 10.8975 2.125 10 2.125C9.10254 2.125 8.375 2.85254 8.375 3.75C8.375 4.64746 9.10254 5.375 10 5.375Z"
                fill="#1D1D1F" />
            <path
                d="M10 11.625C10.8975 11.625 11.625 10.8975 11.625 10C11.625 9.10254 10.8975 8.375 10 8.375C9.10254 8.375 8.375 9.10254 8.375 10C8.375 10.8975 9.10254 11.625 10 11.625Z"
                fill="#1D1D1F" />
            <path
                d="M10 17.875C10.8975 17.875 11.625 17.1475 11.625 16.25C11.625 15.3525 10.8975 14.625 10 14.625C9.10254 14.625 8.375 15.3525 8.375 16.25C8.375 17.1475 9.10254 17.875 10 17.875Z"
                fill="#1D1D1F" />
        </svg>
        <ul class="gh-header-subnav">
            {{#foreach navigation from="5"}}
            <li class="nav-{{slug}} gh-subnav-item"><a class="gh-subnav-item-link" href="{{url absolute=" true"}}">{{label}}</a></li>
            {{/foreach}}
        </ul>
    </li> --}}
</ul>
{{/if}}

<script>
    let navItems = document.querySelectorAll('.gh-header-navigation li');
    var prevItem;
    var subItems = [];
    for (var i = 0; i <= navItems.length; i++) {
        let item = navItems[i];
        let label = item?.children[0]?.innerHTML;
        if (label && label.trim().indexOf('--') == 0) {
            subItems.push(item);
        } else {
        if (subItems.length > 0) {
            // Append list to previous item
            let subNavHTML = '<span class="nav-trigger">  <svg width="10" height="7" viewBox="0 0 10 7" fill="none" xmlns="https://www.w3.org/2000/svg"><path d="M8.825 0.158333L5 3.975L1.175 0.158333L0 1.33333L5 6.33333L10 1.33333L8.825 0.158333Z" fill-opacity="0.54"/></svg></span><ul class="gh-header-subnav">';
            for (var j = 0; j < subItems.length; j++) {
                subItems[j].classList.add('gh-subnav-item-link');
                subNavHTML += '<li class="' + subItems[j].classList + ' gh-subnav-item">' + subItems[j].innerHTML.replace('-- ', '') + '</li>';
                subItems[j].remove();
            }
            subNavHTML += '</ul>';
            prevItemInner = prevItem.children[0].innerHTML;
            prevItem.innerHTML = '<a>' + prevItemInner + '</a>';
            prevItem.innerHTML = '' + prevItem.innerHTML + subNavHTML + '';
            prevItem.classList.add('gh-subnav-icon');
            prevItem.classList.add('show');
            prevItem.classList.remove('gh-header-nav-item');
        }
        // Reset
        prevItem = item;
        subItems = [];
    }
    
    }
</script>