{{#get "posts" filter="(tag:ai,tag:artificial-intelligence,tag:machine-learning,tag:generative-ai)+tag:-hash-ai+tag:-jobs+tag:-job+tag:-careers+tag:-hiring+tag:-events+tag:-event+tag:-people+tag:-product+tag:-company+tag:-companies" include="authors,tags" limit="8" order="published_at desc" as |ai_posts|}}
{{#if ai_posts}}
<section class="sc-ai-slider">
    <div class="sc-ai-slider-inner">
        <div class="sc-ai-slider-header">
            <h2 class="sc-ai-slider-title">Artificial Intelligence</h2>
            <div class="sc-ai-slider-nav">
                <button class="sc-ai-nav-btn sc-ai-nav-btn--prev" aria-label="Previous">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 18 18" fill="none">
                                            <g clip-path="url(#clip0_298_7377)">
                                                <path d="M11.3184 14.9401L6.42836 10.0501C5.85086 9.47256 5.85086 8.52756 6.42836 7.95006L11.3184 3.06006" stroke="#EBEFF2" stroke-width="1.5" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/>
                                            </g>
                                            <defs>
                                                <clipPath id="clip0_298_7377">
                                                    <rect width="18" height="18" fill="white" transform="matrix(-1 0 0 1 18 0)"/>
                                                </clipPath>
                                            </defs>
                                        </svg>
                </button>
                <button class="sc-ai-nav-btn sc-ai-nav-btn--next" aria-label="Next">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 18 18" fill="none">
                                            <g clip-path="url(#clip0_298_7379)">
                                                <path d="M6.68164 14.9401L11.5716 10.0501C12.1491 9.47256 12.1491 8.52756 11.5716 7.95006L6.68164 3.06006" stroke="#EBEFF2" stroke-width="1.5" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/>
                                            </g>
                                            <defs>
                                                <clipPath id="clip0_298_7379">
                                                    <rect width="18" height="18" fill="white"/>
                                                </clipPath>
                                            </defs>
                                        </svg>
                </button>
            </div>
        </div>

        <div class="sc-ai-slider-wrapper">
            <div class="sc-ai-slider-track">
                {{#foreach ai_posts}}
                <article class="sc-ai-slide">
                    <a class="sc-ai-slide-img-wrap" href="{{url}}" aria-label="{{title}}">
                        {{#if feature_image}}
                        <img src="{{img_url feature_image size="2000"}}" alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}" class="sc-ai-slide-img" loading="lazy" />
                        {{else}}
                        <div class="sc-ai-slide-img-placeholder">
                            <svg width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.2)" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                        </div>
                        {{/if}}
                    </a>
                    <div class="sc-ai-slide-body">
                        <div class="sc-ai-slide-meta">
                            {{#primary_author}}
                            {{#if profile_image}}
                            <img class="sc-ai-slide-avatar" src="{{img_url profile_image size="xs"}}" alt="{{name}}" />
                            {{else}}
                            <div class="sc-ai-slide-avatar sc-ai-slide-avatar--letter">{{name.[0]}}</div>
                            {{/if}}
                            <span class="sc-ai-slide-author">{{name}}</span>
                            {{/primary_author}}
                            <span class="sc-ai-slide-bullet">•</span>
                            <span class="sc-ai-slide-date">{{date published_at timeago="true"}}</span>
                        </div>
                        <h3 class="sc-ai-slide-title">
                            <a href="{{url}}">{{title}}</a>
                        </h3>
                        {{#if excerpt}}
                        <p class="sc-ai-slide-excerpt">{{excerpt}}</p>
                        {{/if}}
                        <div class="sc-ai-slide-tags">
                            {{#foreach tags visibility="all" limit="4"}}
                            {{#if (match slug "^hash-")}}
                            <span class="sc-ai-slide-tag">{{name}}</span>
                            {{else}}
                            <a class="sc-ai-slide-tag" href="{{url}}">{{name}}</a>
                            {{/if}}
                            {{/foreach}}
                        </div>
                    </div>
                </article>
                {{/foreach}}
            </div>
        </div>
    </div>
</section>

<script>
(function() {
    const slider = document.querySelector('.sc-ai-slider');
    if (!slider) return;

    const tagChips = slider.querySelectorAll('.sc-ai-slide-tag');
    tagChips.forEach((chip) => {
        const value = chip.textContent ? chip.textContent.trim() : '';
        if (value.startsWith('#')) {
            chip.textContent = value.slice(1).trim();
        }
    });
    
    const track = slider.querySelector('.sc-ai-slider-track');
    const prevBtn = slider.querySelector('.sc-ai-nav-btn--prev');
    const nextBtn = slider.querySelector('.sc-ai-nav-btn--next');
    const slides = slider.querySelectorAll('.sc-ai-slide');
    
    if (!track || !prevBtn || !nextBtn || slides.length === 0) return;
    
    let currentIndex = 0;
    let maxIndex = 0;
    
    function getSlidesPerView() {
        if (window.innerWidth <= 767) return 1;
        if (window.innerWidth <= 1024) return 2;
        if (window.innerWidth <= 1280) return 3;
        return 4;
    }
    
    function updateSlider() {
        const slideWidth = slides[0].offsetWidth;
        const slidesPerView = getSlidesPerView();
        maxIndex = Math.max(0, slides.length - slidesPerView);
        const gap = 18;
        const offset = currentIndex * (slideWidth + gap);
        track.style.transform = `translateX(-${offset}px)`;
        
        prevBtn.disabled = currentIndex === 0;
        nextBtn.disabled = currentIndex >= maxIndex;
        
        prevBtn.style.opacity = currentIndex === 0 ? '0.3' : '1';
        nextBtn.style.opacity = currentIndex >= maxIndex ? '0.3' : '1';
    }
    
    prevBtn.addEventListener('click', () => {
        if (currentIndex > 0) {
            currentIndex--;
            updateSlider();
        }
    });
    
    nextBtn.addEventListener('click', () => {
        if (currentIndex < maxIndex) {
            currentIndex++;
            updateSlider();
        }
    });
    
    updateSlider();
    
    let resizeTimeout;
    window.addEventListener('resize', () => {
        clearTimeout(resizeTimeout);
        resizeTimeout = setTimeout(() => {
            currentIndex = 0;
            updateSlider();
        }, 200);
    });
})();
</script>
{{/if}}
{{/get}}
