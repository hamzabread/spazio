{{!< default-contact}} 
{{#post}} {{#if featured}} {{#match @page.show_title_and_feature_image}} <div
    class="gh-post-head page-head{{^if feature_image}} without-image{{/if}}">
    {{#if feature_image}}
    <picture>
        <source srcset="{{img_url feature_image size="3000" format="webp" }} 3000w, {{img_url feature_image size="2000"
            format="webp" }} 2000w, {{img_url feature_image size="1200" format="webp" }} 1200w, {{img_url feature_image
            size="1000" format="webp" }} 1000w, {{img_url feature_image size="800" format="webp" }} 800w, {{img_url
            feature_image size="500" format="webp" }} 500w" sizes="100vw" type="image/webp">
        <img srcset="{{img_url feature_image size=" 3000"}} 3000w, {{img_url feature_image size="2000" }} 2000w,
            {{img_url feature_image size="1200" }} 1200w, {{img_url feature_image size="1000" }} 1000w, {{img_url
            feature_image size="800" }} 800w, {{img_url feature_image size="500" }} 500w" sizes="100vw"
            src="{{img_url feature_image size="3000"}}"
            alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
            class="gh-post-feature-image" />
    </picture>
    {{/if}}
    <div class="gh-post-head-wrapper page-head-wrapper gh-container{{#match @custom.header_type " Logo with bottom
        navigation" }} with-big-header{{else match @custom.header_type "Author with bottom navigation" }}
        with-big-header{{/match}}">
        {{> "breadcrumbs"}}
        <div class="gh-post-head-content">
            <div class="gh-post-head-content-container">
                <h1 class="gh-post-page-title">{{title}}</h1>
                {{#if excerpt}}
                <p class="gh-post-page-excerpt">{{excerpt}}</p>
                {{/if}}
            </div>
        </div>
    </div>
    </div>
    {{/match}}
    {{else}}
    {{#match @page.show_title_and_feature_image}}
    <div class="gh-container">
        {{> "breadcrumbs"}}
    </div>
    <div class="gh-post-head gh-container page-head{{^if feature_image}} without-image{{/if}}">
        <div class="gh-post-head-wrapper page-head-wrapper{{^if feature_image}} without-image{{/if}}">
            {{#if feature_image}}
            <picture>
                <source srcset="{{img_url feature_image size="1600" format="webp" }} 1600w, {{img_url feature_image
                    size="1200" format="webp" }} 1200w, {{img_url feature_image size="1000" format="webp" }} 1000w,
                    {{img_url feature_image size="800" format="webp" }} 800w, {{img_url feature_image size="500"
                    format="webp" }} 500w" sizes="(min-width: 816px) 736px, 90vw" type="image/webp">
                <img srcset="{{img_url feature_image size=" 1600"}} 1600w, {{img_url feature_image size="1200" }} 1200w,
                    {{img_url feature_image size="1000" }} 1000w, {{img_url feature_image size="800" }} 800w, {{img_url
                    feature_image size="500" }} 500w" sizes="(min-width: 816px) 736px, 90vw"
                    src="{{img_url feature_image size="1600"}}"
                    alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
                    class="gh-post-feature-image" />
            </picture>
            {{/if}}
            <div class="gh-post-head-content">
                <div class="gh-post-head-content-container">
                    <h1 class="gh-post-page-title">{{title}}</h1>
                    {{#if excerpt}}
                    <p class="gh-post-page-excerpt">{{excerpt}}</p>
                    {{/if}}
                </div>
            </div>
        </div>
    </div>
    {{/match}}
    {{/if}}

    {{/post}}

    <main class="main">
        <div class="container py-14 lg:pt-32 lg:pb-20 template-contact-container">
            <div class="contact-form-container-ad flex flex-wrap justify-between lg:flex-nowrap"
                style="flex-direction: row-reverse;">
                <div class=" lg:w-1/2 lg:max-w-[640px]">
                    <div class="wpcf7 js" id="wpcf7-f407-o2" lang="en-US" dir="ltr">
                        <form action="https://formspree.io/f/xrgwqvpb" method="post">
                            <div class="form-row">
                                <div class="form-column">
                                    <label for="contact-nome">
                                        {{t "Name"}} <span class="text-bright-red-600 p3 p3--ns">* <span
                                                class="sr-only">{{t "Required"}}</span></span>
                                    </label>
                                    <input class="form-input" id="contact-name" required="" aria-required="true"
                                        aria-invalid="false" value="" type="text"
                                        name="your-name">
                                </div>
                                <div class="form-column">
                                    <label for="contact-email">
                                        {{t "Email"}} <span class="text-bright-red-600 p3 p3--ns">* <span
                                                class="sr-only">{{t "Required"}}</span></span>
                                    </label>
                                    <input class="form-input" id="contact-email" required="" aria-required="true"
                                        aria-invalid="false" value=""
                                        type="email" name="your-email">
                                </div>
                            </div>

                            <div class="form-row">
                                <div class="form-column">
                                    <label for="contact-email">
                                        {{t "Company"}}<span class="text-bright-red-600 p3 p3--ns">* <span
                                                class="sr-only">{{t "Required"}}</span></span>
                                    </label>
                                    <input class="form-input" id="contact-name" required="" aria-required="true"
                                        aria-invalid="false" value="" type="text"
                                        name="company-name">
                                </div>
                                <div class="form-column">
                                    <label for="contact-name">
                                        {{t "Telegram"}}
                                    </label>
                                    <input class="form-input" id="contact-name" required="" aria-required="true"
                                        aria-invalid="false"  value="" type="text"
                                        name="your-name">
                                </div>
                            </div>
                            <div class="form-row">
                                <label for="contact-name">
                                    {{t "Website"}}
                                </label>
                                <input class="form-input" aria-invalid="false" 
                                    value="" type="text" name="text-website">
                            </div>
                            <label for="contact-name">
                                {{t "Choose an option"}}
                            </label>
                            <div class="form-row">
                                <div class="form-column">
                                    <select class="form-select" id="contact-reason" required="" aria-required="true"
                                        aria-invalid="false" name="menu-130">
                                        <option value="">{{t "—Choose an option—"}}</option>
                                        <option value="Ad Network">{{t "Advertising network"}}</option>
                                        <option value="Agency/Intermerdiary">{{t "Agency/intermediary"}}</option>
                                        <option value="Conference/Event">{{t "Conference/event"}}</option>
                                        <option value="Crypto Mining">{{t "Cryptocurrency mining"}}</option>
                                        <option value="Currency/Coin project">{{t "Currency/coin project"}}</option>
                                        <option value="Finance/Investment">{{t "Finance/investment"}}</option>
                                        <option value="Giochi/giochi d'azzardo">{{t "Games/gambling"}}</option>
                                        <option value="Tecnologia generale">{{t "General technology"}}</option>
                                        <option value="Other (Crypto-related)">{{t "Otherrc"}}
                                        </option>
                                        <option value="Other (Non-crypto related)">{{t "Othernrc"}}
                                        </option>
                                    </select>
                                </div>

                                <div class="form-column" style="display: flex;">
                                    <a href="https://docsend.com/v/tk4mp/spaziocrypto-media-kit"
