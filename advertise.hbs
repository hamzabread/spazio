                                                </g>
                                                <title id="titleid33966ca59"></title>
                                            </svg>
                                            <span style="margin-left:10px">{{t "Media Kit"}}</span>
                                        </div>
                                    </a>
                                </div>

                            </div>
                            <div class="form-row">
                                <label for="contact-name">
                                    {{t "Write your message"}}
                                </label>
                                <textarea rows="10" name="message" class="form-message" required style="height: 11rem;"></textarea>
                            </div>
                            <div class="form-row">
                                <input type="submit" value="{{t "Send"}}"
                                    class="form-button contact-us-btn button-change-color"
                                    style="width:100%;min-height:48px;">
                            </div>
                        </form>
                    </div>
                </div>
                <div class="lg:w-1/2">
                    <img src={{asset '/imagesAndIcons/advertising.webp' }}
                        class="block relative lg:-right-19 lg:top-5 mt-10 lg:mt-0 top-0" alt="" decoding="async"
                        loading="lazy" style="width: 100%;">
                </div>
            </div>
            <div
                class="contact-box-color max-w-[1080px] mx-auto flex flex-wrap items-center p-6 mt-6 lg:mt-24 contact-details bg-grey-100 dark:bg-dark-grey-500 rounded-2xl lg:p-10 lg:flex-nowrap lg:justify-between contact-box-text-align">
                <div class="contact-address w-full max-w-[480px] lg:w-1/2">
                    <h2 class="mb-3 font-bold leading-6 p3" style="margin-bottom: 14px;">Spaziocrypto Limited</h2>
                    <address class="not-italic leading-6 p4 font-body">
                        <p>Galton Tower, 22, Civic Close, B1 2NW</p>
                        <p>Birmingham</p>
                        <p>United Kingdom</p>
                        <p>Phone: +44 07400250775</p>
                    </address>
                </div>
                <ul
                    class="w-full pt-4 mt-4 border-t lg:mt-0 lg:pt-0 lg:w-1/2 lg:grid lg:grid-cols-2-max gap-y-8 gap-x-20 contact-emails border-t-grey-300 dark:border-t-dark-grey-700 lg:border-none lg:justify-end">
                    <li class="mb-5 lg:mb-0 last:mb-0">
                        <h4 class="mb-1 font-sans font-bold leading-6 p3 contact-box-email-title">{{t "General"}}</h4>
                        <address class="not-italic leading-6 p4 font-body custom-email" style="color: #F19021;">
                            <a href="mailto:info@spaziocrypto.com" target="">info@spaziocrypto.com</a>
                        </address>
                    </li>
                    {{!-- <li class="mb-5 lg:mb-0 last:mb-0">
                        <h4 class="mb-1 font-sans font-bold leading-6 p3">Editor in Chief</h4>
                        <address class="not-italic leading-6 text-blue-600 p4 font-body dark:text-lime-600">
                            <a href="mailto:editorinchief@beincrypto.com" target="">editorinchief@spaziocrypto.com</a>
                        </address>
                    </li> --}}
                    <li class="mb-5 lg:mb-0 last:mb-0 contact-box-email">
                        <h4 class="mb-1 font-sans font-bold leading-6 p3 contact-box-email-title">{{t "Marketing and
                            Sales"}}
                        </h4>
                        <address class="not-italic leading-6 p4 font-body custom-email" style="color: #F19021;">
                            <a href="mailto:marketing@spaziocrypto.com" target="">marketing@spaziocrypto.com</a>
                        </address>
                    </li>
                    {{!-- <li class="mb-5 lg:mb-0 last:mb-0">
