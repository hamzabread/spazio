                                                        style="fill: white; transition-property: none;">
                                                    </path>
                                                </g>
                                                <g>
                                                    <g>
                                                        <path
                                                            d="M35.4,37.8c-4.5,0-8.3-3.7-8.3-8.3s3.7-8.3,8.3-8.3s8.3,3.7,8.3,8.3S39.9,37.8,35.4,37.8z M35.4,24.2    c-3,0-5.4,2.4-5.4,5.4s2.4,5.4,5.4,5.4c3,0,5.4-2.4,5.4-5.4S38.3,24.2,35.4,24.2z"
                                                            style="fill: white; transition-property: none;">
