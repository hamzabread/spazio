<script>
(function(){
  const wrap = document.querySelector('.video-wrapper-it');
  if(!wrap) return;

  const iframe  = wrap.querySelector('iframe[data-src]');
  const isMobile = window.matchMedia('(max-width:768px)').matches;
  const MOBILE_SCROLL_THRESHOLD = 350;

  const CONSENT_KEY = 'sc_termly_choice_it_v1'; // accept | reject

  function getSaved(){
    try{
      return localStorage.getItem(CONSENT_KEY) || sessionStorage.getItem(CONSENT_KEY);
    }catch(e){
      return sessionStorage.getItem(CONSENT_KEY);
    }
  }
  function setSaved(v){
    try{ localStorage.setItem(CONSENT_KEY, v); }catch(e){}
    try{ sessionStorage.setItem(CONSENT_KEY, v); }catch(e){}
  }

  function loadIframe(){
    if(iframe && !iframe.getAttribute('src')){
      iframe.setAttribute('src', iframe.getAttribute('data-src'));
    }
  }

  function showDesktop(){
    wrap.style.display = 'block';
    requestAnimationFrame(()=>{
      wrap.classList.add('is-visible');
      wrap.style.pointerEvents = 'auto';
      loadIframe();
    });
  }

  function showMobileAfterScroll(){
    wrap.style.display = 'block';
    wrap.style.opacity = '0';
    wrap.style.pointerEvents = 'none';

    function reveal(){
      wrap.classList.add('is-visible');
      wrap.style.opacity = '1';
      wrap.style.pointerEvents = 'auto';
      loadIframe();
      window.removeEventListener('scroll', onScroll, {passive:true});
    }

    function onScroll(){
      if(window.scrollY >= MOBILE_SCROLL_THRESHOLD) reveal();
    }

    if(window.scrollY >= MOBILE_SCROLL_THRESHOLD) reveal();
    else window.addEventListener('scroll', onScroll, {passive:true});
  }

  function startWidgetIfAccepted(){
    if(isMobile) showMobileAfterScroll();
    else showDesktop();
  }

  function stopWidget(){
    wrap.style.display = 'none';
    wrap.style.pointerEvents = 'none';
  }

  const saved = getSaved();
  if(saved === 'reject'){ stopWidget(); return; }
  if(saved === 'accept'){ startWidgetIfAccepted(); return; }

  // For demo on localhost, show immediately
  if(location.host === 'localhost:2368'){
    startWidgetIfAccepted();
    return;
  }

  function getCookieStr(){ return document.cookie || ''; }

  function looksAcceptedFromTermly(){
    try{
      const c = getCookieStr().toLowerCase();
      if(c.includes('termly')){
        if(c.includes('reject') || c.includes('decline')) return 'reject';
        if(c.includes('accept') || c.includes('agree') || c.includes('consent') || c.includes('true')) return 'accept';
      }

      try{
        for(let i=0;i<localStorage.length;i++){
          const key = (localStorage.key(i) || '').toLowerCase();
          if(!key.includes('termly')) continue;

          const raw = localStorage.getItem(localStorage.key(i)) || '';
          const v = raw.toLowerCase();

          if(v.includes('reject') || v.includes('decline')) return 'reject';
          if(v.includes('accept') || v.includes('agree')) return 'accept';

          try{
            const obj = JSON.parse(raw);
            const s = JSON.stringify(obj).toLowerCase();
            if(s.includes('reject') || s.includes('decline')) return 'reject';
            if(s.includes('accept') || s.includes('agree') || s.includes('"consent":true') || s.includes('categories') || s.includes('preferences')) return 'accept';
          }catch(e){}
        }
      }catch(e){}

      return null;
    }catch(e){
      return null;
    }
  }

  const inferred = looksAcceptedFromTermly();
  if(inferred === 'reject'){
    setSaved('reject');
    stopWidget();
    return;
  }
  if(inferred === 'accept'){
    setSaved('accept');
    startWidgetIfAccepted();
    return;
  }

  const ACCEPT_WORDS = [
    'accept','agree','allow','ok','consent',
    'accetta','accetto','accetta tutto','accetta tutti','accetta e continua',
    'consenti','va bene','ho capito','ok'
  ];
  const REJECT_WORDS = [
    'reject','decline','disagree','deny','refuse',
    'rifiuta','rifiuto','nega','non accetto'
  ];

  function textOf(el){
    return ((el.getAttribute('aria-label') || '') + ' ' + (el.textContent || '')).trim().toLowerCase();
  }
  function matchesAny(t, arr){
    return arr.some(w => t === w || t.includes(w));
  }

  function wireTermlyButtons(){
    const candidates = Array.from(document.querySelectorAll('button, a, [role="button"]'));
    for(const el of candidates){
      if(el.__scTermlyBound) continue;
      const t = textOf(el);
      if(!t) continue;

      if(matchesAny(t, ACCEPT_WORDS)){
        el.__scTermlyBound = true;
        el.addEventListener('click', ()=>{
          setSaved('accept');
          setTimeout(startWidgetIfAccepted, 200);
          setTimeout(startWidgetIfAccepted, 800);
        }, true);
      }

      if(matchesAny(t, REJECT_WORDS)){
        el.__scTermlyBound = true;
        el.addEventListener('click', ()=>{
          setSaved('reject');
          stopWidget();
        }, true);
      }
    }
  }

  const obs = new MutationObserver(wireTermlyButtons);
  obs.observe(document.documentElement, {subtree:true, childList:true, attributes:true});
  wireTermlyButtons();

  stopWidget();
})();
</script>

