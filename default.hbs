<style>
/* ============================= */
/*  GOOGLE FONTS                 */
/* ============================= */
@import url('https://fonts.googleapis.com/css2?family=Epilogue:wght@400;500;600;700;800&family=Manrope:wght@400;500;600;700;800&display=swap');

/* ============================= */
/*  VISIBILE SOLO HOME IT        */
/* ============================= */
.home-it-only{display:none;}
html[data-home-it="true"] .home-it-only{display:block;}

/* ============================= */
/*  ✅ TERMLY SEMPRE SOPRA       */
/* ============================= */
.termly-styles-root,
#termly-code-snippet,
[class*="termly"]{
  z-index:2147483647 !important;
}

/* ============================= */
/*  ANIMAZIONE DESKTOP           */
/* ============================= */
@keyframes slowSlideInRight{
  from{transform:translateX(120px);opacity:0}
  to{transform:translateX(0);opacity:1}
}

/* ============================= */
/*  WRAPPER BASE                 */
/* ============================= */
.video-wrapper-it{
  position:fixed;
  bottom:88px;     /* base */
  right:16px;
  width:330px;
  height:187px;

  /* 🔥 sotto Termly */
  z-index:2147482000;

  overflow:visible;
  pointer-events:none;

  /* di default: nascosto finchè non c'è consenso */
  display:none;
  opacity:0;
  transform:translateX(120px);
}

/* ✅ DESKTOP: spostalo più su per NON coprire il banner 970x90 */
@media (min-width: 769px){
  .video-wrapper-it{
    bottom: 150px; /* 90px banner + ~24px label/close + margine */
  }
}

/* Desktop: quando attivo */
.video-wrapper-it.is-visible{
  display:block;
  pointer-events:auto;
  animation:slowSlideInRight .9s cubic-bezier(.22,.61,.36,1) forwards;
}

/* ============================= */
/*  MOBILE                       */
/*  - solo dopo consenso + scroll*/
/*  - no animazioni              */
/*  - più in basso a destra      */
/* ============================= */
@media (max-width:768px){
  .video-wrapper-it{
    bottom:16px;
    right:8px;
    transform:none!important;
    animation:none!important;
  }
  .video-wrapper-it.is-visible{
    animation:none!important;
    transform:none!important;
    opacity:1!important;
  }
}

/* ============================= */
/*  VIDEO BOX – GLOW ARANCIONE   */
/* ============================= */
#videoBox-it{
  position:absolute;
  inset:0;
  border-radius:22px;

  /* 🔥 lascia uscire il glow */
  overflow:visible;

  background:#000;
  pointer-events:auto;
  z-index:2147482001;

  font-family:'Manrope', sans-serif;
  font-size:14px;
}

/* bordo */
#videoBox-it::before{
  content:"";
  position:absolute;
  inset:-1px;
  border-radius:24px;
  padding:1.5px;
  pointer-events:none;
  z-index:2147482002;

  background:linear-gradient(135deg,
    rgba(255,232,170,.95) 0%,
    rgba(241,144,33,1)    35%,
    rgba(255,170,80,.9)   65%,
    rgba(241,144,33,.95)  100%);

  -webkit-mask:
    linear-gradient(#000 0 0) content-box,
    linear-gradient(#000 0 0);
  -webkit-mask-composite:xor;
  mask-composite:exclude;
}

/* glow */
#videoBox-it::after{
  content:"";
  position:absolute;
  inset:-12px;
  border-radius:30px;
  pointer-events:none;
  z-index:2147482000;

  background:
    radial-gradient(120px 80px at 85% 18%,
      rgba(255,235,180,.55) 0%,
      rgba(241,144,33,.22) 45%,
      rgba(241,144,33,0)   70%),
    linear-gradient(135deg,
      rgba(255,210,120,.35) 0%,
      rgba(241,144,33,.28) 35%,
      rgba(241,144,33,.12) 65%,
      rgba(255,200,110,.20) 100%);

  filter:blur(14px);
  opacity:.95;
}

/* ============================= */
/*  INNER (CLIP VIDEO)           */
/* ============================= */
.video-inner-it{
  position:absolute;
  inset:0;
  border-radius:22px;
  overflow:hidden;            /* clip SOLO qui */
  background:#000;
  z-index:2147482001;
}

/* 🔥 FIX DEFINITIVO SPAZI BIANCHI */
.video-inner-it iframe{
  width:100%!important;
  height:100%!important;
  display:block!important;
  border:0!important;
  background:#000!important;
  object-fit:cover;
}

/* ============================= */
/*  TYPOGRAPHY                   */
/* ============================= */
#videoBox-it .badge-latest,
#videoBox-it .video-close{
  font-family:'Epilogue', sans-serif;
  font-weight:600;
  letter-spacing:.25px;
}
#videoBox-it span,
#videoBox-it a,
#videoBox-it button{
  font-family:'Manrope', sans-serif;
  font-weight:500;
}

/* ============================= */
/*  BADGE ISCRIVITI              */
/* ============================= */
.badge-latest{
  position:absolute;
  top:9px;
  left:9px;
  display:inline-flex;
  align-items:center;
  gap:5px;
  padding:3px 8px;
  border-radius:9999px;
  background:#ff2b2b;
  color:#fff;
  font-size:10.5px;
  font-weight:700;
  letter-spacing:.25px;
  text-decoration:none;
  line-height:1.2;
  z-index:2147482003;
}
.badge-latest:hover{background:#cc0000;}

.latest-dot{
  width:6px;
  height:6px;
  border-radius:50%;
  background:#fff;
  position:relative;
}
.latest-dot::after{
  content:"";
  position:absolute;
  inset:-3px;
  border-radius:50%;
  border:2px solid rgba(255,255,255,.6);
  animation:pulse 1.4s ease-out infinite;
}
@keyframes pulse{
  0%{transform:scale(.7);opacity:1}
  100%{transform:scale(1.4);opacity:0}
}

/* ============================= */
/*  CLOSE                        */
/* ============================= */
.video-close{
  position:absolute;
  top:7px;
  right:9px;
  width:24px;
  height:24px;
  border-radius:50%;
  border:none;
  background:rgba(0,0,0,.6);
  color:#fff;
  font-size:13px;
  cursor:pointer;
  line-height:24px;
  text-align:center;
  z-index:2147482003;
}

/* ============================= */
/*  SEO NASCOSTO                 */
/* ============================= */
.seo-only{
  position:absolute!important;
  width:1px!important;
  height:1px!important;
  padding:0!important;
  margin:-1px!important;
  overflow:hidden!important;
  clip:rect(0 0 0 0)!important;
  clip-path:inset(50%)!important;
  white-space:nowrap!important;
  border:0!important;
}
</style>

