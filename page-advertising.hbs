{{!< default}}

{{#post}}
<div class="sc-advertising-page custom-advertising-template">
    <div class="sc-advertising-inner gh-container">
        <div class="sc-advertising-layout">
            <aside class="sc-advertising-toc" aria-label="{{t "On this page"}}">
                <div class="sc-advertising-toc-head">
                    <img class="sc-advertising-toc-icon" src="{{asset "imagesAndIcons/on-this-page.svg"}}" alt="" width="32" height="32" loading="lazy" decoding="async" aria-hidden="true">
                    <span>{{t "On this page"}}</span>
                </div>
                <nav class="sc-advertising-toc-nav">
                    <a href="#media-kit-overview" class="sc-advertising-toc-link is-active">{{t "Media Kit Overview"}}</a>
                    <a href="#traffic-analytics" class="sc-advertising-toc-link">{{t "Traffic & Analytics"}}</a>
                    <a href="#social-proof" class="sc-advertising-toc-link">{{t "Social Proof"}}</a>
                    <div class="sc-advertising-toc-group">
                        <span class="sc-advertising-toc-group-label">{{t "Advertising Packages"}}</span>
                        <a href="#company-listing" class="sc-advertising-toc-sublink">{{t "Company Listing"}}</a>
                        <a href="#featured-listing" class="sc-advertising-toc-sublink">{{t "Featured Listing"}}</a>
                        <a href="#press-release" class="sc-advertising-toc-sublink">{{t "Press Release"}}</a>
                        <a href="#sponsored-article" class="sc-advertising-toc-sublink">{{t "Sponsored Article"}}</a>
                        <a href="#event-promotion" class="sc-advertising-toc-sublink">{{t "Event Promotion"}}</a>
                        <a href="#job-listing" class="sc-advertising-toc-sublink">{{t "Job Listing"}}</a>
                    </div>
                </nav>
            </aside>

            <div class="sc-advertising-main">
                <article class="sc-advertising-article">
                    <div class="sc-advertising-hero-shell">
                    <section id="media-kit-overview" class="sc-advertising-section sc-advertising-section--hero">
                            <h1 class="sc-advertising-h1">{{title}}</h1>
                            {{#if excerpt}}
                            <p class="sc-advertising-lede">{{excerpt}}</p>
                            {{else}}
                            <p class="sc-advertising-lede">{{t "Advertising overview default"}}</p>
                            {{/if}}

                            <div class="sc-advertising-chart-card">
                                <div class="sc-advertising-chart-head">
                                    <span class="sc-advertising-chart-title">{{t "2025 Monthly Views"}}</span>
                                    <span class="sc-advertising-chart-badge" aria-hidden="true">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 20 20" fill="none" class="sc-advertising-chart-badge-svg" aria-hidden="true">
                                            <path d="M18.3334 5.83334L11.2501 12.9167L7.08341 8.75001L1.66675 14.1667" stroke="#22C55E" stroke-width="1.66667" stroke-linecap="round" stroke-linejoin="round"/>
                                            <path d="M13.3333 5.83334H18.3333V10.8333" stroke="#22C55E" stroke-width="1.66667" stroke-linecap="round" stroke-linejoin="round"/>
                                        </svg>
                                        +10.25%
                                    </span>
                                </div>
                                <div class="sc-advertising-chart" role="img" aria-label="{{t "2025 Monthly Views chart"}}">
                                    <picture>
                                        <source media="(max-width: 767px)" srcset="{{asset "imagesAndIcons/responsive-graph.svg"}}">
                                        <img class="sc-advertising-chart-svg" src="{{asset "imagesAndIcons/graph-product.svg"}}" alt="" loading="lazy" decoding="async">
                                    </picture>
                                </div>
                            </div>

                        <div class="sc-advertising-stat-grid">
                            <div class="sc-advertising-stat-card">
                                <div class="sc-advertising-chart-head">
                                    <span class="sc-advertising-chart-title">{{t "Monthly Traffic Trends"}}</span>
                                    <span class="sc-advertising-chart-badge sc-advertising-chart-badge--bare" aria-hidden="true">
                                        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M2.5 10.5L6 5.5L9 8L13.5 3.5" stroke="#22C55E" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M10.5 3.5H13.5V6.5" stroke="#22C55E" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                    </span>
                                </div>
                                <div class="sc-advertising-bar-chart" role="img" aria-label="{{t "Monthly Traffic Trends chart"}}">
                                    <img class="sc-advertising-bar-chart-svg" src="{{asset "imagesAndIcons/bar-graph.svg"}}" alt="" loading="lazy" decoding="async">
                                </div>
                            </div>

                            <div class="sc-advertising-stat-card">
                                <div class="sc-advertising-chart-head">
                                    <span class="sc-advertising-chart-title">{{t "Geographic Distribution"}}</span>
                                    <span class="sc-advertising-chart-badge sc-advertising-chart-badge--bare" aria-hidden="true">
                                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#FF6B00" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="12" r="9"/><path d="M3 12h18"/><path d="M12 3a14 14 0 0 1 0 18"/><path d="M12 3a14 14 0 0 0 0 18"/></svg>
                                    </span>
                                </div>

                                <ul class="sc-advertising-geo-list" role="list">
                                    <li class="sc-advertising-geo-row">
                                        <div class="sc-advertising-geo-label">
                                            <span>{{t "North America"}}</span>
                                            <span class="sc-advertising-geo-value">45%</span>
                                        </div>
                                        <div class="sc-advertising-geo-track"><span class="sc-advertising-geo-fill" style="width: 45%"></span></div>
                                    </li>
                                    <li class="sc-advertising-geo-row">
                                        <div class="sc-advertising-geo-label">
                                            <span>{{t "Europe"}}</span>
                                            <span class="sc-advertising-geo-value">30%</span>
                                        </div>
                                        <div class="sc-advertising-geo-track"><span class="sc-advertising-geo-fill" style="width: 30%"></span></div>
                                    </li>
                                    <li class="sc-advertising-geo-row">
                                        <div class="sc-advertising-geo-label">
                                            <span>{{t "Asia"}}</span>
                                            <span class="sc-advertising-geo-value">18%</span>
                                        </div>
                                        <div class="sc-advertising-geo-track"><span class="sc-advertising-geo-fill" style="width: 18%"></span></div>
                                    </li>
                                    <li class="sc-advertising-geo-row">
                                        <div class="sc-advertising-geo-label">
                                            <span>{{t "Others"}}</span>
                                            <span class="sc-advertising-geo-value">7%</span>
                                        </div>
                                        <div class="sc-advertising-geo-track"><span class="sc-advertising-geo-fill" style="width: 7%"></span></div>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </section>

