{{!< default}}

{{#post}}
<main class="sc-about-page sc-about-page-dynamic">
    <section class="sc-about-hero">
        <div class="sc-about-shell">
            <article class="sc-about-hero-card sc-about-hero-card-dynamic">
                <div class="sc-about-hero-copy">
                    {{> breadcrumbs}}

                    {{#if primary_tag}}
                        <span class="sc-about-chip">{{primary_tag.name}}</span>
                    {{else}}
                        <span class="sc-about-chip">{{t "About Us"}}</span>
                    {{/if}}

                    <h1>{{title}}</h1>

                    {{#if custom_excerpt}}
                        <p>{{custom_excerpt}}</p>
                    {{else}}
                        <p>{{excerpt words="42"}}</p>
                    {{/if}}

                    <div class="sc-about-socials">
                        {{#if @site.facebook}}<a href="{{facebook_url}}" target="_blank" rel="noopener" aria-label="Facebook">{{> "icons/facebook"}}</a>{{/if}}
                        {{#if @custom.telegram_link}}<a href="{{@custom.telegram_link}}" target="_blank" rel="noopener" aria-label="Telegram">{{> "icons/telegram"}}</a>{{/if}}
                        {{#if @custom.google_news_link}}<a href="{{@custom.google_news_link}}" target="_blank" rel="noopener" aria-label="Google">{{> "icons/googlenews"}}</a>{{/if}}
                        {{#if @custom.insta_link}}<a href="{{@custom.insta_link}}" target="_blank" rel="noopener" aria-label="Instagram">{{> "icons/instagram"}}</a>{{/if}}
                        {{#if @site.twitter}}<a href="{{twitter_url}}" target="_blank" rel="noopener" aria-label="Twitter">{{> "icons/twitter"}}</a>{{/if}}
                    </div>
                </div>

                <div class="sc-about-hero-image-wrap">
                    {{#if feature_image}}
                        <img class="sc-about-hero-image" src="{{img_url feature_image size="xl"}}" alt="{{title}}" loading="lazy" />
                    {{else}}
                        <img class="sc-about-hero-image" src="{{asset 'imagesAndIcons/aboutustop.png'}}" alt="{{title}}" loading="lazy" />
                    {{/if}}
                </div>
            </article>
        </div>
    </section>

    <section class="sc-about-mission">
        <div class="sc-about-shell">
            <article class="sc-about-mission-card sc-about-mission-card-dynamic">
                <h2>{{t "What"}} <span>{{t "Drives Us"}}</span></h2>
                <p>
                    {{t "Our mission is to be a trusted source for learning about crypto and blockchain by offering clear, research-based content that helps people make informed decisions. Our vision is to build an impartial, collaborative community where knowledge is shared openly and even complex topics become easy to understand for everyone."}}
                </p>
            </article>
        </div>
    </section>

    <section class="sc-about-operate">
        <div class="sc-about-shell">
            <div class="sc-about-operate-head">
                <span class="sc-about-operate-chip">{{t "How We Operate"}}</span>
                <h2>{{t "Impartiality & Transparency"}}</h2>
                <p>{{t "We follow strict editorial guidelines to provide accurate, independent information and maintain full transparency with our readers."}}</p>
            </div>

            <article class="sc-about-operate-card">
                <div class="sc-about-operate-item">
                    <span class="sc-about-operate-icon">
                        <img class="sc-about-icon-image" src="{{asset 'imagesAndIcons/Container.svg'}}" alt="Fact-checking" loading="lazy" />
                    </span>
                    <div>
                        <h3>Fact-Checking &amp; Source Verification</h3>
                        <p>Every piece of information is thoroughly verified before publication</p>
                    </div>
                </div>

                <div class="sc-about-operate-item">
                    <span class="sc-about-operate-icon">
                        <img class="sc-about-icon-image" src="{{asset 'imagesAndIcons/shield.svg'}}" alt="Avoiding sensationalism" loading="lazy" />
                    </span>
                    <div>
                        <h3>Avoiding Sensationalism</h3>
                        <p>We report facts without hype or misleading headlines</p>
                    </div>
                </div>

                <div class="sc-about-operate-item">
                    <span class="sc-about-operate-icon">
                        <img class="sc-about-icon-image" src="{{asset 'imagesAndIcons/ai-icon.svg'}}" alt="Sponsored labeling" loading="lazy" />
                    </span>
                    <div>
                        <h3>Clear Labeling of Sponsored Material</h3>
                        <p>Full transparency about commercial content</p>
                    </div>
                </div>

                <div class="sc-about-operate-item">
                    <span class="sc-about-operate-icon">
                        <img class="sc-about-icon-image" src="{{asset 'imagesAndIcons/medal.svg'}}" alt="Content type distinction" loading="lazy" />
                    </span>
                    <div>
                        <h3>Distinguishing Content Types</h3>
                        <p>Clear separation between news, opinions, and analysis</p>
                    </div>
                </div>
            </article>
        </div>
    </section>

