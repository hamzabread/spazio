{{!< default}}

{{#post}}
<main class="sc-about-page sc-about-page-dynamic">
    <section class="sc-about-hero">
        <div class="sc-about-shell">
            <article class="sc-about-hero-card sc-about-hero-card-dynamic">
                <div class="sc-about-hero-copy">
                    {{> breadcrumbs}}

                    {{#if primary_tag}}
                        <span class="sc-about-chip">{{primary_tag.name}}</span>
                    {{else}}
                        <span class="sc-about-chip">{{t "About Us"}}</span>
                    {{/if}}

                    <h1>{{title}}</h1>

                    {{#if custom_excerpt}}
                        <p>{{custom_excerpt}}</p>
                    {{else}}
                        <p>{{excerpt words="42"}}</p>
                    {{/if}}

                    <div class="sc-about-socials">
                        {{#if @site.facebook}}<a href="{{facebook_url}}" target="_blank" rel="noopener" aria-label="Facebook"><i class="fa fa-facebook"></i></a>{{/if}}
                        {{#if @custom.telegram_link}}<a href="{{@custom.telegram_link}}" target="_blank" rel="noopener" aria-label="Telegram"><i class="fa fa-paper-plane"></i></a>{{/if}}
                        {{#if @custom.insta_link}}<a href="{{@custom.insta_link}}" target="_blank" rel="noopener" aria-label="Instagram"><i class="fa fa-instagram"></i></a>{{/if}}
                        {{#if @site.twitter}}<a href="{{twitter_url}}" target="_blank" rel="noopener" aria-label="Twitter"><i class="fa fa-twitter"></i></a>{{/if}}
                    </div>
                </div>

                <div class="sc-about-hero-image-wrap">
                    {{#if feature_image}}
                        <img class="sc-about-hero-image" src="{{img_url feature_image size="xl"}}" alt="{{title}}" loading="lazy" />
                    {{else}}
                        <img class="sc-about-hero-image" src="{{asset 'imagesAndIcons/aboutustop.png'}}" alt="{{title}}" loading="lazy" />
                    {{/if}}
                </div>
            </article>
        </div>
    </section>

    {{> breaking-news}}

    <section class="sc-about-mission">
        <div class="sc-about-shell">
            <article class="sc-about-mission-card sc-about-mission-card-dynamic gh-content">
                {{{content}}}
            </article>
        </div>
    </section>

    <section class="sc-about-operate">
        <div class="sc-about-shell">
            <div class="sc-about-operate-head">
                <span class="sc-about-operate-chip">{{t "How We Operate"}}</span>
                <h2>{{t "Impartiality & Transparency"}}</h2>
                <p>{{t "We follow strict editorial guidelines to provide accurate, independent information and maintain full transparency with our readers."}}</p>
            </div>

            <article class="sc-about-operate-card">
                {{#get "posts" limit="4" filter="tag:hash-about-operate+visibility:public"}}
                    {{#if posts}}
                        {{#foreach posts}}
                            <div class="sc-about-operate-item">
                                <span class="sc-about-operate-icon">
                                    {{#if feature_image}}
                                        <img class="sc-about-icon-image" src="{{img_url feature_image size="xxs"}}" alt="{{title}}" loading="lazy" />
                                    {{else}}
                                        <i class="fa fa-check" aria-hidden="true"></i>
                                    {{/if}}
                                </span>
                                <div>
                                    <h3>{{title}}</h3>
                                    {{#if custom_excerpt}}
                                        <p>{{custom_excerpt}}</p>
                                    {{else}}
                                        <p>{{excerpt words="16"}}</p>
                                    {{/if}}
                                </div>
                            </div>
                        {{/foreach}}
                    {{else}}
                        {{#get "posts" limit="4" filter="visibility:public"}}
                            {{#foreach posts}}
                                <div class="sc-about-operate-item">
                                    <span class="sc-about-operate-icon"><i class="fa fa-check" aria-hidden="true"></i></span>
                                    <div>
                                        <h3>{{title}}</h3>
                                        {{#if custom_excerpt}}
                                            <p>{{custom_excerpt}}</p>
                                        {{else}}
                                            <p>{{excerpt words="16"}}</p>
                                        {{/if}}
                                    </div>
                                </div>
                            {{/foreach}}
                        {{/get}}
                    {{/if}}
                {{/get}}
            </article>
        </div>
    </section>

    <section class="sc-about-revenue">
        <div class="sc-about-shell">
            <div class="sc-about-revenue-head">
                <span class="sc-about-revenue-chip">{{t "Transparency"}}</span>
                <h2>{{t "Revenue Model"}}</h2>
                <p>{{t "To keep the platform running sustainably, we use transparent revenue channels."}}</p>
            </div>

            <div class="sc-about-revenue-grid">
                {{#get "posts" limit="6" filter="tag:hash-about-revenue+visibility:public"}}
                    {{#if posts}}
                        {{#foreach posts}}
                            <article class="sc-about-revenue-item">
                                <span class="sc-about-revenue-icon">
                                    {{#if feature_image}}
                                        <img class="sc-about-icon-image" src="{{img_url feature_image size="xxs"}}" alt="{{title}}" loading="lazy" />
                                    {{else}}
                                        <i class="fa fa-book" aria-hidden="true"></i>
                                    {{/if}}
                                </span>
                                <h3>{{title}}</h3>
                                {{#if custom_excerpt}}
                                    <p>{{custom_excerpt}}</p>
                                {{else}}
                                    <p>{{excerpt words="18"}}</p>
                                {{/if}}
                            </article>
                        {{/foreach}}
                    {{else}}
                        {{#get "posts" limit="6" filter="visibility:public"}}
                            {{#foreach posts}}
                                <article class="sc-about-revenue-item">
                                    <span class="sc-about-revenue-icon"><i class="fa fa-book" aria-hidden="true"></i></span>
                                    <h3>{{title}}</h3>
                                    {{#if custom_excerpt}}
                                        <p>{{custom_excerpt}}</p>
                                    {{else}}
                                        <p>{{excerpt words="18"}}</p>
                                    {{/if}}
                                </article>
                            {{/foreach}}
                        {{/get}}
                    {{/if}}
                {{/get}}
            </div>
        </div>
    </section>

    {{#get "authors" limit="1"}}
        {{#if authors}}
            {{#foreach authors}}
                <section class="sc-about-riccardo">
                    <div class="sc-about-shell">
                        <div class="sc-about-riccardo-wrap">
                            <div class="sc-about-riccardo-content">
                                <span class="sc-about-riccardo-chip">{{t "Founder & Managing Partner"}}</span>
                                <h2>{{name}}</h2>
                                {{#if bio}}
                                    <p>{{bio}}</p>
                                {{/if}}

                                <div class="sc-about-riccardo-socials">
                                    {{#if website}}<a href="{{website}}" target="_blank" rel="noopener" aria-label="Website"><i class="fa fa-globe" aria-hidden="true"></i></a>{{/if}}
                                    {{#if facebook}}<a href="{{facebook_url}}" target="_blank" rel="noopener" aria-label="Facebook"><i class="fa fa-facebook" aria-hidden="true"></i></a>{{/if}}
                                    {{#if twitter}}<a href="{{twitter_url}}" target="_blank" rel="noopener" aria-label="Twitter"><i class="fa fa-twitter" aria-hidden="true"></i></a>{{/if}}
                                </div>

                                <h3>{{t "Areas Of Expertise"}}</h3>
                                <ul class="sc-about-riccardo-list">
                                    {{#get "tags" limit="6" filter="visibility:public"}}
                                        {{#foreach tags}}
                                            <li>
                                                <span class="sc-about-riccardo-check" aria-hidden="true"><i class="fa fa-check"></i></span>
                                                <span class="sc-about-riccardo-list-text">{{name}}</span>
                                            </li>
                                        {{/foreach}}
                                    {{/get}}
                                </ul>
                            </div>

                            <div class="sc-about-riccardo-media">
                                {{#if profile_image}}
                                    <img class="sc-about-riccardo-main" src="{{img_url profile_image size="l"}}" alt="{{name}}" loading="lazy" />
                                {{/if}}
                                {{#get "posts" limit="4" filter="visibility:public"}}
                                    {{#if posts}}
                                        <div class="sc-about-riccardo-gallery">
                                            {{#foreach posts}}
                                                {{#if feature_image}}
                                                    <img src="{{img_url feature_image size="s"}}" alt="{{title}}" loading="lazy" />
                                                {{/if}}
                                            {{/foreach}}
                                        </div>
                                    {{/if}}
                                {{/get}}
                            </div>
                        </div>

                        {{#get "posts" limit="2" filter="visibility:public"}}
                            {{#if posts}}
                                <div class="sc-about-riccardo-articles">
                                    <h3>{{t "Articles and mentions"}}</h3>
                                    <div class="sc-about-riccardo-articles-grid">
                                        {{#foreach posts}}
                                            <a class="sc-about-riccardo-article-card" href="{{url}}">
                                                {{#if feature_image}}
                                                    <div class="sc-about-article-image" style="background-image: url('{{img_url feature_image size="m"}}');"></div>
                                                {{/if}}
                                                <div class="sc-about-article-content">
                                                    <div class="sc-about-article-meta">
                                                        {{#primary_tag}}<span class="sc-about-article-source">{{name}}</span>{{/primary_tag}}
                                                    </div>
                                                    <h4 class="sc-about-article-title">{{title}}</h4>
                                                    <div class="sc-about-article-footer">
                                                        <span class="sc-about-article-author">{{#primary_author}}{{name}}{{/primary_author}}</span>
                                                    </div>
                                                </div>
                                            </a>
                                        {{/foreach}}
                                    </div>
                                </div>
                            {{/if}}
                        {{/get}}
                    </div>
                </section>
            {{/foreach}}
        {{/if}}
    {{/get}}

    {{#get "authors" limit="6" include="count.posts"}}
        {{#if authors}}
            <section class="sc-about-team">
                <div class="sc-about-shell">
                    <div class="sc-about-team-head">
                        <span class="sc-about-team-chip">{{t "Team Section"}}</span>
                        <h3>{{t "Meet The Team"}}</h3>
                        <p>{{t "The people behind our research, insights, and educational content."}}</p>
                    </div>

                    <div class="sc-about-team-grid">
                        {{#foreach authors}}
                            <article class="sc-about-team-card">
                                {{#if profile_image}}
                                    <a href="{{url}}" aria-label="{{name}}">
                                        <img src="{{img_url profile_image size="s"}}" alt="{{name}}" loading="lazy" />
                                    </a>
                                {{else}}
                                    <a class="sc-about-team-avatar-placeholder" href="{{url}}" aria-label="{{name}}">{{name}}</a>
                                {{/if}}

                                <h4><a href="{{url}}">{{name}}</a></h4>

                                {{#if location}}
                                    <span class="sc-about-team-role">{{location}}</span>
                                {{else}}
                                    <span class="sc-about-team-role">{{t "Contributor"}}</span>
                                {{/if}}

                                {{#if bio}}
                                    <p>{{bio}}</p>
                                {{else}}
                                    <p>{{t "Read this author profile to explore their latest work and insights."}}</p>
                                {{/if}}

                                <div class="sc-about-team-socials">
                                    {{#if website}}<a href="{{website}}" target="_blank" rel="noopener" aria-label="Website"><i class="fa fa-globe" aria-hidden="true"></i></a>{{/if}}
                                    {{#if facebook}}<a href="{{facebook_url}}" target="_blank" rel="noopener" aria-label="Facebook"><i class="fa fa-facebook" aria-hidden="true"></i></a>{{/if}}
                                    {{#if twitter}}<a href="{{twitter_url}}" target="_blank" rel="noopener" aria-label="Twitter"><i class="fa fa-twitter" aria-hidden="true"></i></a>{{/if}}
                                </div>
                            </article>
                        {{/foreach}}
                    </div>
                </div>
            </section>
        {{/if}}
    {{/get}}

    {{> "faq-section"}}
</main>

{{> "never-miss"}}
{{> "subscribe-newsletter"}}
{{/post}}
