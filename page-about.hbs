{{!< default}}

{{#post}}
<main class="sc-about-page">
    <section class="sc-about-hero">
        <div class="sc-about-shell">
            <article class="sc-about-hero-card">
                <div class="sc-about-hero-copy">
                    {{> breadcrumbs}}
                    <span class="sc-about-chip">About Us</span>
                    <h1>Spaziocrypto - The Web3 <span>Community</span></h1>
                    <p>
                        Our vision is to become the leading italian reference point for information and
                        learning in the vast world of cryptocurrencies, blockchain technology and finance.
                        We are determined to create a virtuous environment where access to high quality
                        content is easy, understandable and useful to all.
                    </p>

                    <div class="sc-about-socials">
                        {{#if @site.facebook}}<a href="{{facebook_url}}" target="_blank" rel="noopener" aria-label="Facebook"><i class="fa fa-facebook"></i></a>{{/if}}
                        {{#if @custom.telegram_link}}<a href="{{@custom.telegram_link}}" target="_blank" rel="noopener" aria-label="Telegram"><i class="fa fa-paper-plane"></i></a>{{/if}}
                        <a href="#" aria-label="Google"><i class="fa fa-google"></i></a>
                        {{#if @custom.insta_link}}<a href="{{@custom.insta_link}}" target="_blank" rel="noopener" aria-label="Instagram"><i class="fa fa-instagram"></i></a>{{/if}}
                        {{#if @site.twitter}}<a href="{{twitter_url}}" target="_blank" rel="noopener" aria-label="Twitter"><i class="fa fa-twitter"></i></a>{{/if}}
                    </div>
                </div>

                <div class="sc-about-hero-image-wrap">
                    <img class="sc-about-hero-image" src="{{asset 'imagesAndIcons/aboutustop.png'}}" alt="About us" loading="lazy" />
                </div>
            </article>
        </div>
    </section>

    <section class="sc-about-mission">
        <div class="sc-about-shell">
            <article class="sc-about-mission-card">
                <h2>What <span>Drives Us</span></h2>
                <p>
                    Our mission is to be a trusted source for learning about crypto and blockchain by offering
                    clear, research-based content that helps people make informed decisions. Our vision is to build
                    an impartial, collaborative community where knowledge is shared openly and even complex topics
                    become easy to understand for everyone.
                </p>
            </article>
        </div>
    </section>

    <section class="sc-about-operate">
        <div class="sc-about-shell">
            <div class="sc-about-operate-head">
                <span class="sc-about-operate-chip">How We Operate</span>
                <h2>Impartiality &amp; <span>Transparency</span></h2>
                <p>
                    We follow strict editorial guidelines to provide accurate, independent information and
                    maintain full transparency with our readers.
                </p>
            </div>

            <article class="sc-about-operate-card">
                <div class="sc-about-operate-item">
                    <span class="sc-about-operate-icon"><i class="fa fa-file-text-o" aria-hidden="true"></i></span>
                    <div>
                        <h3>Fact-Checking &amp; Source Verification</h3>
                        <p>Every piece of information is thoroughly verified before publication</p>
                    </div>
                </div>

                <div class="sc-about-operate-item">
                    <span class="sc-about-operate-icon"><i class="fa fa-shield" aria-hidden="true"></i></span>
                    <div>
                        <h3>Avoiding Sensationalism</h3>
                        <p>We report facts without hype or misleading headlines</p>
                    </div>
                </div>

                <div class="sc-about-operate-item">
                    <span class="sc-about-operate-icon"><i class="fa fa-star-o" aria-hidden="true"></i></span>
                    <div>
                        <h3>Clear Labeling of Sponsored Material</h3>
                        <p>Full transparency about commercial content</p>
                    </div>
                </div>

                <div class="sc-about-operate-item">
                    <span class="sc-about-operate-icon"><i class="fa fa-bookmark-o" aria-hidden="true"></i></span>
                    <div>
                        <h3>Distinguishing Content Types</h3>
                        <p>Clear separation between news, opinions, and analysis</p>
                    </div>
                </div>
            </article>
        </div>
    </section>

    <section class="sc-about-revenue">
        <div class="sc-about-shell">
            <div class="sc-about-revenue-head">
                <span class="sc-about-revenue-chip">Transparency</span>
                <h2>Revenue <span>Model</span></h2>
                <p>
                    To keep the platform running sustainably, Spaziocrypto generates revenue through multiple
                    transparent channels.
                </p>
            </div>

            <div class="sc-about-revenue-grid">
                <article class="sc-about-revenue-item">
                    <span class="sc-about-revenue-icon"><i class="fa fa-newspaper-o" aria-hidden="true"></i></span>
                    <h3>Advertising Partnerships</h3>
                    <p>We work with carefully selected advertisers that meet our standards for transparency, legitimacy, and ethical practices.</p>
                </article>

                <article class="sc-about-revenue-item">
                    <span class="sc-about-revenue-icon"><i class="fa fa-users" aria-hidden="true"></i></span>
                    <h3>Events &amp; Seminars</h3>
                    <p>We host events and seminars focused on education, discussion, and knowledge sharing within the crypto and blockchain space.</p>
                </article>

                <article class="sc-about-revenue-item">
                    <span class="sc-about-revenue-icon"><i class="fa fa-magic" aria-hidden="true"></i></span>
                    <h3>Sponsored Content</h3>
                    <p>Sponsored content is always clearly identified to ensure full transparency between editorial and promotional material.</p>
                </article>

                <article class="sc-about-revenue-item">
                    <span class="sc-about-revenue-icon"><i class="fa fa-bookmark-o" aria-hidden="true"></i></span>
                    <h3>Premium Content</h3>
                    <p>We offer optional paid content such as advanced courses and exclusive reports for deeper learning.</p>
                </article>

                <article class="sc-about-revenue-item">
                    <span class="sc-about-revenue-icon"><i class="fa fa-usd" aria-hidden="true"></i></span>
                    <h3>Affiliate Programs</h3>
                    <p>Some links may be affiliate-based, allowing us to earn commissions while maintaining full editorial independence.</p>
                </article>

                <article class="sc-about-revenue-item">
                    <span class="sc-about-revenue-icon"><i class="fa fa-book" aria-hidden="true"></i></span>
                    <h3>Learning Initiatives</h3>
                    <p>Some links may be affiliate-based, allowing us to earn commissions while maintaining full editorial independence.</p>
                </article>
            </div>
        </div>
    </section>
</main>
{{/post}}
