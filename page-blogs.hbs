{{!< default}}

{{#post}}
<section class="sc-blogs-hero" aria-labelledby="sc-blogs-hero-title">
    <div class="gh-container sc-blogs-hero-inner">
        {{#get "posts" limit="1" include="tags,authors" filter="featured:true" order="published_at desc"}}
            {{#if posts}}
                {{#foreach posts}}
                <article class="sc-blogs-featured-card">
                    <a class="sc-blogs-featured-media" href="{{url}}" aria-label="{{title}}">
                        <img src="{{asset 'imagesAndIcons/blog-hero.png'}}" alt="Featured blog hero" class="sc-blogs-featured-image" loading="eager" decoding="async">
                    </a>

                    <a class="sc-blogs-featured-content" href="{{url}}" aria-label="{{title}}">
                        {{#if tags}}
                        <div class="sc-blogs-featured-tags">
                            {{#foreach tags limit="4"}}
                            <span class="sc-blogs-featured-tag">{{name}}</span>
                            {{/foreach}}
                        </div>
                        {{/if}}

                        <h2 id="sc-blogs-hero-title">{{title}}</h2>

                        {{#if excerpt}}
                        <p>{{excerpt}}</p>
                        {{/if}}

                        <div class="sc-blogs-featured-meta">
                            <time datetime="{{date format='YYYY-MM-DD'}}">{{date format="MMM D, YYYY"}}</time>
                            <svg xmlns="http://www.w3.org/2000/svg" width="4" height="4" viewBox="0 0 4 4" fill="none" aria-hidden="true">
                                <circle cx="2" cy="2" r="2" fill="var(--color-muted-legacy)" fill-opacity="0.4"/>
                            </svg>
                            <span>{{reading_time minute=(t "1 min read") minutes=(t "% min read")}}</span>
                        </div>
                    </a>
                </article>
                {{/foreach}}
            {{else}}
                <article class="sc-blogs-featured-card">
                    <img src="{{asset 'imagesAndIcons/blog-hero.png'}}" alt="Featured blog hero" class="sc-blogs-featured-image" loading="eager" decoding="async">
                    <div class="sc-blogs-featured-content">
                        <div class="sc-blogs-featured-tags">
                            <span class="sc-blogs-featured-tag">Crypto</span>
                            <span class="sc-blogs-featured-tag">AI</span>
                            <span class="sc-blogs-featured-tag">Trending</span>
                            <span class="sc-blogs-featured-tag">Token</span>
                        </div>
                        <h2 id="sc-blogs-hero-title">Crypto AI rallying: which tokens are driving the market rebound</h2>
                        <p>The crypto market started 2026 on a more positive note as risk appetite in major assets, meme coins and AI-linked tokens increased. Also, the good regulatory outlook was reinforced by the progress made on the U.S. CLARITY Act.</p>
                        <div class="sc-blogs-featured-meta">
                            <time datetime="2026-03-30">Mar 28, 2026</time>
                            <svg xmlns="http://www.w3.org/2000/svg" width="4" height="4" viewBox="0 0 4 4" fill="none" aria-hidden="true">
                                <circle cx="2" cy="2" r="2" fill="var(--color-muted-legacy)" fill-opacity="0.4"/>
                            </svg>
                            <span>4 min read</span>
                        </div>
                    </div>
                </article>
            {{/if}}
        {{/get}}
    </div>
</section>

<main class="main flex-1">
    <section class="gh-container sc-blogs-next-section">
        {{#get "posts" limit="1" include="tags,authors" filter="featured:true" order="published_at desc"}}
        {{#if posts}}
        {{#foreach posts}}
        <div class="sc-blogs-next-grid">
            <aside class="sc-blogs-next-col sc-blogs-next-col-left" aria-label="Author details and share">
                <article class="sc-blogs-author-detail-card">
                    {{#primary_author}}
                    <img src="{{#if profile_image}}{{img_url profile_image size='s'}}{{else}}{{asset 'imagesAndIcons/AuthorAvatarDefault.jpg'}}{{/if}}" alt="{{name}}" class="sc-blogs-author-avatar" loading="lazy" decoding="async">
                    <h3>{{name}}</h3>
                    <p class="sc-blogs-author-role">{{t "Contributor"}}</p>
                    <p class="sc-blogs-author-bio">{{#if bio}}{{bio}}{{else}}{{t "Editorial contributor at"}} {{@site.title}}{{/if}}</p>
                    <div class="sc-blogs-author-links">
                        {{#if website}}
                        <a href="{{website}}" target="_blank" rel="noopener" aria-label="Author website">
                            {{> "icons/external"}}
                            <span>{{t "Website"}}</span>
                        </a>
                        {{/if}}
                        {{#if twitter}}
                        <a href="https://x.com/{{twitter}}" target="_blank" rel="noopener" aria-label="Author on X">
                            {{> "icons/twitter"}}
                            <span>@{{twitter}}</span>
                        </a>
                        {{/if}}
                    </div>
                    {{/primary_author}}
                </article>

                <article class="sc-blogs-share-card" aria-label="Share this article">
                    <h4>SHARE</h4>
                    <div class="sc-blogs-share-row">
                        <a href="https://www.facebook.com/sharer/sharer.php?u={{url absolute='true'}}" class="sc-blogs-share-btn" aria-label="Share on Facebook" target="_blank" rel="noopener">{{> "icons/facebook"}}</a>
                        <a href="https://t.me/share/url?url={{url absolute='true'}}&text={{title}}" class="sc-blogs-share-btn" aria-label="Share on Telegram" target="_blank" rel="noopener">{{> "icons/telegram"}}</a>
                        <a href="https://news.google.com/search?q={{title}}" class="sc-blogs-share-btn" aria-label="Open in Google News" target="_blank" rel="noopener">{{> "icons/googlenews"}}</a>
                        <a href="https://x.com/intent/post?url={{url absolute='true'}}&text={{title}}" class="sc-blogs-share-btn" aria-label="Share on X" target="_blank" rel="noopener">{{> "icons/twitter"}}</a>
                        <a href="https://www.linkedin.com/sharing/share-offsite/?url={{url absolute='true'}}" class="sc-blogs-share-btn" aria-label="Share on LinkedIn" target="_blank" rel="noopener">{{> "icons/linkedin"}}</a>
                    </div>
                </article>

                <article class="sc-blogs-likes-card">
                    <img src="{{asset 'imagesAndIcons/likes.png'}}" alt="Likes" class="sc-blogs-likes-image" loading="lazy" decoding="async">
                </article>
            </aside>

            <section class="sc-blogs-next-col sc-blogs-next-col-center" aria-label="Main blog story">
                <article class="sc-blogs-main-card">
                    {{#if feature_image}}
                    <img src="{{img_url feature_image size='xl'}}" alt="{{title}}" class="sc-blogs-main-card-image" loading="lazy" decoding="async">
                    {{/if}}
                </article>

                <article class="sc-blogs-main-content gh-content" aria-label="Blog article content">
                    {{content}}
                </article>
            </section>

            <aside class="sc-blogs-next-col sc-blogs-next-col-right" aria-label="Article widgets">
                <article class="sc-blogs-right-card sc-blogs-market-card">
                    <div class="sc-blogs-market-head">
                        <div class="sc-blogs-market-coin">
                            <img src="{{asset 'imagesAndIcons/bitcoin.svg'}}" alt="Bitcoin" loading="lazy" decoding="async">
                            <div>
                                <h4>Bitcoin</h4>
                                <p>BTC/USD</p>
                            </div>
                        </div>
                        <div class="sc-blogs-market-price">
                            <strong>$82,585.24</strong>
                            <span>-6%</span>
                        </div>
                    </div>
                    <div class="sc-blogs-market-graph" aria-hidden="true">
                        <svg xmlns="http://www.w3.org/2000/svg" width="295" height="76" viewBox="0 0 295 76" fill="none">
                            <path d="M0 76V0L36.875 20L73.75 30L110.625 10L147.5 25L184.375 15L221.25 30L258.125 20L295 25V76H0Z" fill="url(#paint0_linear_683_9152)"/>
                            <defs>
                                <linearGradient id="paint0_linear_683_9152" x1="0" y1="0" x2="0" y2="7600" gradientUnits="userSpaceOnUse">
                                    <stop stop-color="#90CAF9" stop-opacity="0.4"/>
                                    <stop offset="1" stop-color="#90CAF9" stop-opacity="0"/>
                                </linearGradient>
                            </defs>
                        </svg>
                    </div>
                </article>

                <article class="sc-blogs-right-card sc-blogs-newsletter-card">
                    <div class="sc-blogs-newsletter-inner">
                        <img src="{{asset 'imagesAndIcons/email.svg'}}" alt="Newsletter" class="sc-blogs-newsletter-icon" loading="lazy" decoding="async">
                        <div class="sc-blogs-newsletter-copy">
                            <h4>SUBSCRIBE TO THE NEWSLETTE</h4>
                            <p>Spaziocrypto brings you the weekly summary of major Web3-related news.</p>
                            <a href="#" class="sc-blogs-newsletter-btn">Subscribe</a>
                        </div>
                    </div>
                </article>

                <article class="sc-blogs-right-card sc-blogs-article-tags-card">
                    <h4>In this Article</h4>
                    <img src="{{asset 'imagesAndIcons/crypto-row.svg'}}" alt="Article coins" class="sc-blogs-crypto-row-image" loading="lazy" decoding="async">
                </article>

                <article class="sc-blogs-right-card sc-blogs-language-card" aria-label="Read this article in multiple languages">
                    <h4 class="sc-blogs-language-head">Read this article in...</h4>
                    <ul>
                        <li>
                            <a href="{{url}}" class="is-active">
                                <span class="sc-blogs-language-left"><span>{{locale}}</span></span>
                                <span class="sc-blogs-language-current">Current</span>
                            </a>
                        </li>
                        {{#foreach translations}}
                        <li><a href="{{url}}"><span class="sc-blogs-language-left"><span>{{locale}}</span></span></a></li>
                        {{/foreach}}
                    </ul>
                </article>

                <article class="sc-blogs-right-card sc-blogs-suggested-card">
                    <h4>Suggested article</h4>
                    <div class="sc-blogs-suggested-media">
                        <img src="{{asset 'imagesAndIcons/suggested-article .png'}}" alt="Suggested article" loading="lazy" decoding="async">
                        <span class="sc-blogs-suggested-badge">AI GENERATED IMAGE</span>
                    </div>
                    <div class="sc-blogs-suggested-meta">
                        <img src="{{asset 'imagesAndIcons/joseph.svg'}}" alt="James Hall" loading="lazy" decoding="async">
                        <span>James Hall</span>
                        <span aria-hidden="true">•</span>
                        <span>2 hours ago</span>
                    </div>
                    <h5>Ilya Lichtenstein is free: the spectre of the Bitfinex mega-hack is back in the news</h5>
                    <p>Ilya Lichtenstein, author of the $10 billion-plus maxi hack at Bitfinex, was released early thanks to the First Step Act. The case reignites the debate on AI...</p>
                    <div class="sc-blogs-suggested-tags">
                        <span>Crypto</span>
                        <span>Hack</span>
                    </div>
                </article>
            </aside>
        </div>
        {{/foreach}}
        {{/if}}
        {{/get}}

    </section>
</main>
{{/post}}
