{{!< default}}

{{#post}}
<section class="sc-contact-hero sc-career-hero" aria-labelledby="sc-careers-hero-title">
    <div class="sc-contact-hero-inner sc-career-hero-inner gh-container">
        <span class="sc-contact-hero-chip">Future of Crypto Media</span>
        <h1 id="sc-careers-hero-title">Build the Future of Web3 <span>Journalism With Us</span></h1>
        <p>Join a fast-growing, independent crypto media platform trusted by readers worldwide.</p>
    </div>
</section>

<main class="main flex-1">
    <section class="sc-careers-jobs" aria-labelledby="sc-careers-jobs-title">
        <div class="gh-container sc-careers-jobs-inner">
            <h2 id="sc-careers-jobs-title" class="sc-careers-jobs-title">Open Job <span>Positions</span></h2>

            {{#get "posts" filter="tag:positions" include="tags" order="published_at desc" limit="all"}}
                {{#if posts}}
                    {{#foreach posts}}
                        <article class="sc-careers-job-card">
                            <div class="sc-careers-job-top">
                                <h3>{{title}}</h3>
                                <a href="{{url}}" class="sc-careers-job-link sc-careers-job-link-desktop" aria-label="Apply now for {{title}}">
                                    Apply Now
                                    <span aria-hidden="true">↗</span>
                                </a>
                            </div>
                            <p>{{excerpt}}</p>
                            <ul class="sc-careers-job-meta">
                                <li>
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                                        <path d="M12.0837 7.50033C12.0837 8.65091 11.1509 9.58366 10.0003 9.58366C8.84974 9.58366 7.91699 8.65091 7.91699 7.50033C7.91699 6.34973 8.84974 5.41699 10.0003 5.41699C11.1509 5.41699 12.0837 6.34973 12.0837 7.50033Z" stroke="#EBEFF2" stroke-width="1.25"/>
                                        <path d="M11.0482 14.5783C10.7671 14.849 10.3914 15.0003 10.0005 15.0003C9.60949 15.0003 9.23383 14.849 8.95274 14.5783C6.37891 12.0843 2.92965 9.29824 4.61175 5.25343C5.52124 3.06643 7.70444 1.66699 10.0005 1.66699C12.2965 1.66699 14.4797 3.06643 15.3892 5.25343C17.0692 9.29316 13.6283 12.0929 11.0482 14.5783Z" stroke="#EBEFF2" stroke-width="1.25"/>
                                        <path d="M15 16.667C15 17.5875 12.7614 18.3337 10 18.3337C7.23857 18.3337 5 17.5875 5 16.667" stroke="#EBEFF2" stroke-width="1.25" stroke-linecap="round"/>
                                    </svg>
                                    <span>{{#has tag="#remote"}}100% Remote{{else}}{{#has tag="#on-site"}}On-Site{{else}}{{#has tag="#onsite"}}On-Site{{else}}{{#has tag="#hybrid"}}Hybrid{{else}}Remote{{/has}}{{/has}}{{/has}}{{/has}}</span>
                                </li>
                                <li>
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                                        <circle cx="10" cy="10" r="7.5" stroke="#EBEFF2" stroke-width="1.25"/>
                                        <path d="M10 6.25V10.2L12.7 11.8" stroke="#EBEFF2" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
                                    </svg>
                                    <span>{{#has tag="#full-time"}}Full time{{else}}{{#has tag="#part-time"}}Part time{{else}}{{#has tag="#contract"}}Contract{{else}}{{#has tag="#internship"}}Internship{{else}}Full time{{/has}}{{/has}}{{/has}}{{/has}}</span>
                                </li>
                            </ul>
                            <a href="{{url}}" class="sc-careers-job-link sc-careers-job-link-mobile" aria-label="Apply now for {{title}}">
                                Apply Now
                                <span aria-hidden="true">↗</span>
                            </a>
                        </article>
                    {{/foreach}}
                {{else}}
                    <article class="sc-careers-job-card">
                        <div class="sc-careers-job-top">
                            <h3>No open positions right now</h3>
                        </div>
                        <p>We are not hiring at the moment, but new roles will appear here soon.</p>
                    </article>
                {{/if}}
            {{/get}}
        </div>
    </section>

    <section class="gh-container">
        {{content}}
    </section>
</main>

{{> "faq-section"}}
{{/post}}
