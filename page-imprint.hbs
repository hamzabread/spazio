{{!< default}}

{{#post}}
<div class="sc-imprint-page">
<section class="sc-contact-hero" aria-labelledby="sc-imprint-hero-title">
    <div class="sc-contact-hero-inner gh-container">
        <span class="sc-contact-hero-chip">Legal Information</span>
        <h1 id="sc-imprint-hero-title">Imprint & Legal <span>Disclosure</span></h1>
